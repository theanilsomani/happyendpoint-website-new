---
import { Icon } from 'astro-icon/components';

interface Props {
  label: string;
  value: string;
  icon?: string;
}

const { label, value, icon } = Astro.props;
---

<div class="flex items-center gap-3 rounded-lg border border-border bg-card p-4 transition-colors hover:border-border-strong">
  {icon && (
    <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-md bg-brand-500/10">
      <Icon name={icon} class="h-5 w-5 text-brand-600" />
    </div>
  )}
  <div>
    <p class="text-xs font-medium uppercase tracking-wider text-foreground-muted">{label}</p>
    <p class="mt-0.5 text-sm font-bold text-foreground">{value}</p>
  </div>
</div>
