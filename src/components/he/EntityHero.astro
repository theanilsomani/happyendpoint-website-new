---
import { Icon } from 'astro-icon/components';

export interface Props {
  eyebrow?: string;        // e.g. "API" or "Dataset"
  title: string;
  tagline?: string;
  badges?: string[];       // e.g. format/version chips
  primaryCta?: { label: string; href: string; external?: boolean };
  secondaryCta?: { label: string; href: string };
  logoUrl?: string;
  icon?: string;
}

const { eyebrow, title, tagline, badges = [], primaryCta, secondaryCta, logoUrl, icon = 'lucide:box' } = Astro.props;
---

<section class="relative bg-background pt-8 pb-4 md:pt-12 md:pb-6">
  <div class="container">
    <div class="flex flex-col gap-8 lg:flex-row lg:items-start lg:justify-between lg:gap-12">
      <div class="flex flex-col gap-6 md:flex-row md:items-start md:gap-8 flex-1">
        <div class="flex h-14 w-14 shrink-0 items-center justify-center rounded-2xl bg-background border border-border shadow-sm md:h-20 md:w-20">
          {logoUrl ? (
            <img src={logoUrl} alt={title} class="h-10 w-10 md:h-14 md:w-14 object-contain" />
          ) : (
            <Icon name={icon} class="h-8 w-8 md:h-10 md:w-10 text-brand-600" />
          )}
        </div>
        <div class="flex-1 min-w-0">
          <div class="flex flex-col items-start gap-3">
            <div class="flex flex-wrap items-center gap-2.5">
              {eyebrow && (
                <span class="rounded-full bg-brand-500/10 px-2 py-0.5 text-[10px] font-bold uppercase tracking-wider text-brand-700 dark:text-brand-400">
                  {eyebrow}
                </span>
              )}
              {badges.map(b => (
                <span class="text-[11px] font-semibold text-foreground-muted">{b}</span>
              ))}
            </div>
            
            <h1 class="text-2xl font-bold tracking-tight text-foreground md:text-3xl">{title}</h1>
            
            {tagline && (
              <p class="max-w-2xl text-base leading-relaxed text-foreground-secondary md:text-lg">
                {tagline}
              </p>
            )}

            {(primaryCta || secondaryCta) && (
              <div class="mt-2 flex flex-wrap gap-3">
                {primaryCta && (
                  <a
                    href={primaryCta.href}
                    target={primaryCta.external ? '_blank' : undefined}
                    rel={primaryCta.external ? 'noopener' : undefined}
                    class="inline-flex items-center gap-2 rounded-lg bg-brand-700 px-5 py-2.5 text-sm font-bold text-white transition hover:bg-brand-800 hover:scale-[1.02] active:scale-[0.98]"
                  >
                    {primaryCta.label}
                    {primaryCta.external && <Icon name="lucide:arrow-up-right" class="h-4 w-4" />}
                  </a>
                )}
                {secondaryCta && (
                  <a
                    href={secondaryCta.href}
                    class="inline-flex items-center rounded-lg border border-border-strong bg-background px-5 py-2.5 text-sm font-bold text-foreground transition hover:bg-secondary hover:scale-[1.02] active:scale-[0.98]"
                  >
                    {secondaryCta.label}
                  </a>
                )}
              </div>
            )}
          </div>
        </div>
      </div>

      <div class="w-full lg:w-auto lg:shrink-0">
        <slot name="right" />
      </div>
    </div>
  </div>
</section>
