---
import { Icon } from 'astro-icon/components';

export interface FeatureRow {
  title: string;
  body: string;
  bullets: string[];
  imagePosition: 'left' | 'right';
}

export interface Props {
  rows: FeatureRow[];
}

const { rows } = Astro.props;
---

{rows.map((row, i) => {
  const isAltBg = i % 2 === 1;
  const imgRight = row.imagePosition === 'right';

  return (
    <section class={isAltBg ? 'bg-background-secondary border-y border-border' : 'bg-background'}>
      <div class="container py-16 md:py-20">
        <div class={`grid gap-12 lg:grid-cols-2 lg:items-center ${imgRight ? '' : 'lg:[&>*:first-child]:order-2'}`}>
          <!-- Text column -->
          <div>
            <h2 class="text-2xl font-bold text-foreground md:text-3xl">{row.title}</h2>
            <p class="mt-4 text-lg text-foreground-secondary">{row.body}</p>
            <ul class="mt-6 space-y-3">
              {row.bullets.map(bullet => (
                <li class="flex items-start gap-3">
                  <Icon name="lucide:check-circle-2" class="mt-0.5 h-5 w-5 shrink-0 text-brand-500" />
                  <span class="text-foreground-secondary">{bullet}</span>
                </li>
              ))}
            </ul>
          </div>

          <!-- Image placeholder column -->
          <div class={imgRight ? '' : 'lg:order-first'}>
            <div class="flex aspect-video w-full items-center justify-center rounded-2xl border border-border bg-background-secondary text-sm text-foreground-muted shadow-sm">
              Image placeholder
            </div>
          </div>
        </div>
      </div>
    </section>
  );
})}
