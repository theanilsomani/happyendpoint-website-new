---
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import EntityHero from '@/components/he/EntityHero.astro';
import EntityCard from '@/components/he/EntityCard.astro';
import EntityGrid from '@/components/he/EntityGrid.astro';
import Breadcrumbs from '@/components/he/Breadcrumbs.astro';
import FAQSection from '@/components/he/FAQSection.astro';
import type { CollectionEntry } from 'astro:content';

export interface Props {
  topic: CollectionEntry<'topics'>;
  apis: CollectionEntry<'apis'>[];
  datasets: CollectionEntry<'datasets'>[];
  subTopics?: CollectionEntry<'topics'>[];
  breadcrumbs: Array<{ label: string; href?: string }>;
  hubHref: string;
}

const { topic, apis, datasets, subTopics = [], breadcrumbs, hubHref } = Astro.props;
const { title, description, eyebrow, isHub, faqItems, vertical } = topic.data;

const verticalLabel: Record<string, string> = {
  'real-estate': 'Real Estate Data',
  ecommerce: 'Ecommerce Data',
  finance: 'Finance Data',
  travel: 'Travel Data',
};

const defaultFaqs = [
  {
    question: `How is this data delivered?`,
    answer: `APIs deliver data on demand via HTTPS - one request, one JSON response. Datasets are bulk files (JSON or CSV) purchased as a snapshot and downloaded directly. See the <a href="/library" class="text-brand-600 underline">API library</a> and <a href="/datasets" class="text-brand-600 underline">datasets page</a> for full listings.`,
  },
  {
    question: 'Are free samples available?',
    answer: 'Yes. Most datasets ship with a free sample at identical schema to the paid version. <a href="/free-datasets" class="text-brand-600 underline">Browse free samples here</a>.',
  },
  {
    question: 'How do I subscribe to an API?',
    answer: 'All APIs are sold on RapidAPI. Click through to the API page, choose a plan, and get your API key through RapidAPI\'s dashboard.',
  },
];

const faqs = faqItems.length > 0 ? faqItems : defaultFaqs;
---

<MarketingLayout title={title} description={description}>
  <Breadcrumbs items={breadcrumbs} />

  <EntityHero
    eyebrow={eyebrow ?? verticalLabel[vertical]}
    title={title}
    tagline={description}
    icon={vertical === 'real-estate' ? 'lucide:building-2' : vertical === 'ecommerce' ? 'lucide:shopping-bag' : vertical === 'finance' ? 'lucide:trending-up' : 'lucide:plane'}
  />

  <article class="container max-w-3xl py-12 prose prose-headings:font-bold prose-headings:text-foreground prose-p:text-foreground-secondary prose-a:text-brand-600 prose-code:text-brand-700 prose-code:bg-background-secondary prose-code:px-1 prose-code:rounded prose-li:text-foreground-secondary">
    <slot />
  </article>

  {subTopics.length > 0 && (
    <section class="border-t border-border bg-background-secondary py-12">
      <div class="container">
        <h2 class="text-2xl font-bold text-foreground md:text-3xl">Browse by market</h2>
        <div class="mt-8">
          <EntityGrid columns={3}>
            {subTopics.map(st => (
              <EntityCard
                variant="platform"
                title={st.data.title}
                href={`${hubHref}${st.id.split('-').pop()}/`}
                description={st.data.description}
                tags={[st.data.targetKeyword]}
              />
            ))}
          </EntityGrid>
        </div>
      </div>
    </section>
  )}

  {apis.length > 0 && (
    <section class="container py-12">
      <h2 class="text-2xl font-bold text-foreground md:text-3xl">
        {isHub ? 'APIs in this category' : 'Available APIs'}
      </h2>
      <div class="mt-8">
        <EntityGrid columns={3}>
          {apis.map(a => (
            <EntityCard
              variant="api"
              title={a.data.name}
              href={`/library/${a.id}`}
              description={a.data.description}
              tags={a.data.tags}
            />
          ))}
        </EntityGrid>
      </div>
    </section>
  )}

  {datasets.length > 0 && (
    <section class="border-t border-border bg-background-secondary py-12">
      <div class="container">
        <h2 class="text-2xl font-bold text-foreground md:text-3xl">
          {isHub ? 'Datasets in this category' : 'Available datasets'}
        </h2>
        <div class="mt-8">
          <EntityGrid columns={3}>
            {datasets.map(d => (
              <EntityCard
                variant="dataset"
                title={d.data.name}
                href={`/datasets/${d.id}`}
                description={d.data.description}
                metrics={[
                  { label: 'Records', value: d.data.recordCount },
                  { label: 'Format', value: d.data.format },
                ]}
                badge={d.data.price.toLowerCase() === 'free' ? 'Free' : undefined}
                tags={d.data.tags}
              />
            ))}
          </EntityGrid>
        </div>
      </div>
    </section>
  )}

  <FAQSection faqs={faqs} />

  <section class="border-t border-border bg-background py-16">
    <div class="container max-w-2xl text-center">
      <h2 class="text-2xl font-bold text-foreground md:text-3xl">Ready to start?</h2>
      <p class="mt-4 text-foreground-secondary">Download a free sample dataset or browse the full API catalog to evaluate before subscribing.</p>
      <div class="mt-8 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
        <a href="/free-datasets" class="inline-flex items-center justify-center rounded-lg bg-brand-600 px-6 py-3 text-sm font-semibold text-white hover:bg-brand-700 transition-colors">
          Browse free samples
        </a>
        <a href="/contact" class="inline-flex items-center justify-center rounded-lg border border-border px-6 py-3 text-sm font-semibold text-foreground hover:bg-background-secondary transition-colors">
          Talk to us
        </a>
      </div>
    </div>
  </section>
</MarketingLayout>
