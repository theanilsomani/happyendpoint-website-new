---
import { Icon } from 'astro-icon/components';

interface Props {
  pricing?: string;
  rapidApiUrl?: string;
  variant?: 'api' | 'dataset';
  isFree?: boolean;
  external?: boolean;
  purchaseUrl?: string;
}

const { pricing, rapidApiUrl, variant = 'api', isFree = false, external = true, purchaseUrl } = Astro.props;

const isDataset = variant === 'dataset';
const hasPurchaseUrl = isDataset && !!purchaseUrl;

const ctaLabel = isDataset
  ? (hasPurchaseUrl ? (isFree ? 'Download Free Dataset' : 'Buy on Payhip') : (isFree ? 'Get Free Dataset' : 'Inquire about pricing'))
  : 'View pricing on RapidAPI';
const ctaHref = isDataset
  ? (hasPurchaseUrl ? purchaseUrl! : '/contact')
  : (rapidApiUrl ?? '/contact');
const ctaExternal = isDataset ? hasPurchaseUrl : external;
const note = isDataset
  ? (hasPurchaseUrl
      ? (isFree ? 'Free instant download via Payhip. No account required.' : 'One-time payment. Instant download via Payhip after purchase.')
      : (isFree ? 'Submit your details and we\'ll send you a secure download link.' : 'Contact us to purchase this dataset. We\'ll send you a secure download link.'))
  : 'Current plans, free tier limits, and per-request pricing live on RapidAPI - always up to date.';
const trustBadge = isDataset
  ? (hasPurchaseUrl ? 'Secure checkout via Payhip' : 'Secure delivery via email')
  : 'Secure billing via RapidAPI';
---

<div class="rounded-xl border border-border bg-card p-6 shadow-sm">
  <h3 class="text-sm font-semibold uppercase tracking-wider text-foreground-muted">Pricing</h3>
  <div class="mt-4">
    <p class="text-2xl font-bold text-foreground">
      {pricing || 'See Plans'}
    </p>
    <p class="mt-2 text-sm leading-relaxed text-foreground-secondary">
      {note}
    </p>
  </div>

  <div class="mt-6">
    <a
      href={ctaHref}
      target={ctaExternal ? "_blank" : undefined}
      rel={ctaExternal ? "noopener" : undefined}
      class="inline-flex w-full items-center justify-center gap-2 rounded-lg bg-brand-700 px-4 py-3 text-sm font-bold text-white transition-all hover:bg-brand-800 hover:scale-[1.02] active:scale-[0.98]"
    >
      {ctaLabel}
      <Icon name={ctaExternal ? "lucide:external-link" : "lucide:arrow-right"} class="h-4 w-4" />
    </a>
  </div>

  <div class="mt-4 flex items-center justify-center gap-2">
    <Icon name="lucide:shield-check" class="h-4 w-4 text-emerald-500" />
    <span class="text-xs font-medium text-foreground-muted">{trustBadge}</span>
  </div>
</div>
