---
import JsonLd from '@/components/seo/JsonLd.astro';
import { faqPageSchema } from '@/lib/schema-ld';

export interface Props {
  title?: string;
  faqs: Array<{ question: string; answer: string }>;
  isNested?: boolean;
}
const { title = 'Frequently asked questions', faqs, isNested = false } = Astro.props;
---

{faqs.length > 0 && (
  <section class={isNested ? "" : "border-t border-border bg-background py-16"}>
    <div class={isNested ? "" : "container max-w-3xl"}>
      <h2 class="text-xl font-bold text-foreground md:text-2xl">{title}</h2>
      <div class="mt-8 divide-y divide-border">
        {faqs.map(f => (
          <details class="group py-4">
            <summary class="flex cursor-pointer list-none items-start justify-between gap-4 text-base font-semibold text-foreground">
              <span>{f.question}</span>
              <span class="mt-1 text-foreground-muted transition group-open:rotate-45">+</span>
            </summary>
            <div class="mt-3 text-sm leading-relaxed text-foreground-secondary" set:html={f.answer} />
          </details>
        ))}
      </div>
    </div>
  </section>
  <JsonLd schema={faqPageSchema(faqs)} />
)}
