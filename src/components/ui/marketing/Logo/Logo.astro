---
/**
 * Logo Component — SVG brand logo
 *
 * Renders the Happy Endpoint SVG logo at responsive sizes.
 * Falls back to a monogram badge if the SVG is missing.
 */
import { cn } from '@/lib/cn';
import siteConfig from '@/config/site.config';

interface Props {
  size?: 'sm' | 'md' | 'lg' | 'xl' | '2xl';
  forceDark?: boolean;
  variant?: 'logomark' | 'full';
  class?: string;
  letter?: string;
}

const {
  size = 'md',
  class: className,
} = Astro.props;

const sizeClasses: Record<string, string> = {
  sm:    'h-5',
  md:    'h-6',
  lg:    'h-8',
  xl:    'h-12',
  '2xl': 'h-24',
};

const heightClass = sizeClasses[size] ?? sizeClasses.md;
---

<img
  src="/happyendpoint-com-logo.svg"
  alt={siteConfig.branding.logo.alt}
  class={cn('w-auto shrink-0', heightClass, className)}
  width="200"
  height="60"
  loading="eager"
  decoding="async"
/>
