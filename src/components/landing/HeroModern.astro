---
import Icon from '@/components/ui/primitives/Icon/Icon.astro';

interface ApiCard {
  title: string;
  icon: string;
  color: string;
}

const row1 = [
  { title: 'Cloudflare Bypass', icon: 'shield-check', color: 'bg-orange-500' },
  { title: 'Brave Search', icon: 'compass', color: 'bg-blue-500' },
  { title: 'Best Buy Search', icon: 'shopping-bag', color: 'bg-blue-600' },
  { title: 'Audible Search', icon: 'headphones', color: 'bg-yellow-500' },
];
const row2 = [
  { title: 'Google Maps', icon: 'map-pin', color: 'bg-green-500' },
  { title: 'LinkedIn Job Suggest', icon: 'linkedin', color: 'bg-blue-700' },
  { title: 'Email Verification', icon: 'mail-check', color: 'bg-indigo-500' },
  { title: 'TikTok Video', icon: 'simple-icons:tiktok', color: 'bg-pink-500' },
];
const row3 = [
  { title: 'Amazon Product', icon: 'shopping-cart', color: 'bg-yellow-500' },
  { title: 'Disposable Email', icon: 'ghost', color: 'bg-purple-600' },
  { title: 'Real Estate Data', icon: 'home', color: 'bg-emerald-500' },
  { title: 'Youtube Video', icon: 'simple-icons:youtube', color: 'bg-red-500' },
];
const row4 = [
  { title: 'Weibo Search', icon: 'message-square', color: 'bg-yellow-600' },
  { title: 'Pinterest User Info', icon: 'simple-icons:pinterest', color: 'bg-pink-600' },
  { title: 'AI Content', icon: 'bot', color: 'bg-violet-500' },
  { title: 'X Data', icon: 'x-twitter', color: 'bg-sky-500' },
];

interface PlatformLogo {
  name: string;
  /** URL-encoded path under /companies-logo/ — encode '&' and "'" so HTML+browsers stay happy. */
  src: string;
}

const platformLogos: PlatformLogo[] = [
  { name: 'Bayut',           src: '/companies-logo/Bayut_logo.svg' },
  { name: 'Property Finder', src: '/companies-logo/Property_Finder_logo.svg' },
  { name: 'Fotocasa',        src: '/companies-logo/Logo_Fotocasa.svg' },
  { name: 'Tesco',           src: '/companies-logo/Tesco_Logo.svg' },
  { name: 'Sephora',         src: '/companies-logo/Sephora_logo.svg' },
  { name: 'IKEA',            src: '/companies-logo/Ikea_logo.svg' },
  { name: 'H&M',             src: '/companies-logo/HM-Logo.svg' },
  { name: "Kohl's",          src: '/companies-logo/Kohl%27s_logo.svg' },
  { name: 'Priceline',       src: '/companies-logo/Priceline_logo.svg' },
  { name: 'Morningstar',     src: '/companies-logo/Morningstar_Logo.svg' },
  { name: 'Klarna',     src: '/companies-logo/Klarna_logo.svg' },
];
---

<section class="relative overflow-hidden bg-background pt-20 pb-12 lg:pt-24 lg:pb-16">
  <!-- Decorative background elements -->
  <div class="absolute inset-0 -z-10 bg-grid-pattern [mask-image:radial-gradient(ellipse_at_center,transparent_20%,black)] opacity-10 dark:opacity-20"></div>
  <div class="absolute top-0 right-0 -z-10 h-[600px] w-[600px] bg-brand-500/15 blur-[120px] rounded-full translate-x-1/3 -translate-y-1/2"></div>
  <div class="absolute bottom-0 left-0 -z-10 h-[500px] w-[500px] bg-blue-600/10 blur-[100px] rounded-full -translate-x-1/4 translate-y-1/4"></div>

  <div class="container relative">
    <div class="grid gap-12 lg:grid-cols-2 lg:items-center">
      <!-- Content column -->
      <div class="flex flex-col items-center text-center lg:items-start lg:text-left">
        <div class="flex flex-wrap items-center justify-center lg:justify-start gap-3 animate-fade-in">
          <span class="inline-flex items-center gap-1.5 rounded-full border border-border bg-card/50 backdrop-blur-sm px-3 py-1 text-xs font-medium text-foreground-secondary shadow-sm dark:bg-white/[0.05] dark:border-white/10 dark:text-foreground">
            <span class="text-amber-400 text-sm">★</span> 5.0 rating
          </span>
          <span class="inline-flex items-center gap-1.5 rounded-full border border-border bg-card/50 backdrop-blur-sm px-3 py-1 text-xs font-medium text-foreground-secondary shadow-sm dark:bg-white/[0.05] dark:border-white/10 dark:text-foreground">
            <Icon name="users" class="h-3.5 w-3.5 text-brand-500" /> 1k+ API community
          </span>
        </div>

        <h1 class="mt-7 text-4xl font-bold tracking-tight text-foreground sm:text-5xl lg:text-5xl xl:text-6xl animate-slide-up">
          Web scraping, made <span class="text-brand-600 dark:text-brand-500">easy</span> with APIs
        </h1>

        <p class="mt-5 max-w-xl text-lg text-foreground-secondary animate-slide-up delay-1">
          Get onboard the #1 platform enabling forward-thinking companies to leverage the full potential of web data through +50 ready-to-use scraping APIs.
        </p>

        <div class="mt-9 flex flex-col sm:flex-row items-center gap-4 w-full sm:w-auto animate-slide-up delay-2">
          <a
            href="/library"
            class="group inline-flex items-center justify-center gap-2 w-full sm:w-auto rounded-lg bg-brand-700 px-7 py-3.5 text-sm font-semibold text-white shadow-lg shadow-brand-700/10 transition-all hover:bg-brand-800 hover:shadow-xl hover:shadow-brand-700/20 hover:scale-[1.02] active:scale-[0.98] dark:bg-brand-600 dark:hover:bg-brand-500"
          >
            Get started — For free
            <Icon name="arrow-right" class="h-4 w-4 transition-transform group-hover:translate-x-1" />
          </a>
          <a
            href="/library"
            class="inline-flex items-center justify-center gap-2 w-full sm:w-auto rounded-lg border border-border bg-card/40 backdrop-blur-md px-7 py-3.5 text-sm font-semibold text-foreground transition-all hover:bg-secondary hover:translate-y-[-1px] hover:shadow-md active:scale-[0.98] dark:border-white/20 dark:bg-white/[0.08] dark:hover:bg-white/[0.12]"
          >
            <Icon name="layout-grid" class="h-4 w-4" />
            Browse API library
          </a>
        </div>
      </div>

      <!-- Right content: API Cloud -->
      <div class="relative hidden lg:block animate-fade-in delay-3" aria-hidden="true">
        <div class="relative flex h-[350px] flex-col gap-4 justify-center overflow-hidden [mask-image:radial-gradient(ellipse_at_center,black_30%,transparent_70%)] opacity-90">
          
          <!-- Row 1 -->
          <div class="flex gap-4 justify-center -translate-x-8">
            {row1.map((card, idx) => (
              <div class="group flex items-center gap-2.5 rounded-full border border-border bg-card px-3.5 py-2 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-md cursor-default shrink-0">
                <div class={`flex h-6 w-6 shrink-0 items-center justify-center rounded-full ${card.color} text-white shadow-inner`}>
                  <Icon name={card.icon} class="h-3.5 w-3.5" />
                </div>
                <span class="text-xs font-semibold text-foreground whitespace-nowrap">{card.title}</span>
              </div>
            ))}
          </div>

          <!-- Row 2 -->
          <div class="flex gap-4 justify-center translate-x-4">
            {row2.map((card, idx) => (
              <div class="group flex items-center gap-2.5 rounded-full border border-border bg-card px-3.5 py-2 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-md cursor-default shrink-0">
                <div class={`flex h-6 w-6 shrink-0 items-center justify-center rounded-full ${card.color} text-white shadow-inner`}>
                  <Icon name={card.icon} class="h-3.5 w-3.5" />
                </div>
                <span class="text-xs font-semibold text-foreground whitespace-nowrap">{card.title}</span>
              </div>
            ))}
          </div>

          <!-- Row 3 -->
          <div class="flex gap-4 justify-center -translate-x-12">
            {row3.map((card, idx) => (
              <div class="group flex items-center gap-2.5 rounded-full border border-border bg-card px-3.5 py-2 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-md cursor-default shrink-0">
                <div class={`flex h-6 w-6 shrink-0 items-center justify-center rounded-full ${card.color} text-white shadow-inner`}>
                  <Icon name={card.icon} class="h-3.5 w-3.5" />
                </div>
                <span class="text-xs font-semibold text-foreground whitespace-nowrap">{card.title}</span>
              </div>
            ))}
          </div>

          <!-- Row 4 -->
          <div class="flex gap-4 justify-center translate-x-8">
            {row4.map((card, idx) => (
              <div class="group flex items-center gap-2.5 rounded-full border border-border bg-card px-3.5 py-2 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-md cursor-default shrink-0">
                <div class={`flex h-6 w-6 shrink-0 items-center justify-center rounded-full ${card.color} text-white shadow-inner`}>
                  <Icon name={card.icon} class="h-3.5 w-3.5" />
                </div>
                <span class="text-xs font-semibold text-foreground whitespace-nowrap">{card.title}</span>
              </div>
            ))}
          </div>

        </div>

        <!-- Floating decorative icons -->
        <div class="absolute -top-4 -right-4 animate-pulse text-brand-500/10 pointer-events-none">
          <Icon name="lucide:code-2" class="h-20 w-20 rotate-12" />
        </div>
        <div class="absolute -bottom-8 left-0 animate-pulse text-primary/10 delay-1000 pointer-events-none">
          <Icon name="lucide:database" class="h-24 w-24 -rotate-12" />
        </div>
      </div>
    </div>

    <!-- Platform logos: muted, monochrome, hover restores brand colours.
         Left-aligned on desktop to match the rest of the homepage's section titles. -->
    <div class="mt-12 lg:mt-16 animate-fade-in delay-3">
      <p class="text-center text-[11px] font-bold uppercase tracking-[0.2em] text-foreground-muted/80 lg:text-left mb-4">
        Trusted by data-driven companies worldwide
      </p>
      
      <div class="relative overflow-x-auto no-scrollbar mask-horizontal cursor-grab active:cursor-grabbing select-none py-4">
        <div class="logo-perspective-container">
          <div class="flex w-max animate-infinite-scroll gap-12 items-center hover:[animation-play-state:paused]">
            {[...platformLogos, ...platformLogos, ...platformLogos].map(logo => (
              <div class="flex items-center justify-center w-[110px] h-[38px] shrink-0 transition-transform duration-300 hover:scale-105">
              <img
                src={logo.src}
                alt={`${logo.name} logo`}
                class="hero-logo-img max-h-full max-w-full object-contain"
                loading="lazy"
              />
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
  </div>
</section>

<style>
  .perspective-1000 {
    perspective: 1000px;
  }

  /* Mute the logos with grayscale + lower opacity */
  .hero-logo-img {
    filter: grayscale(100%);
    opacity: 0.45;
    transition: all 0.3s ease;
  }
  
  .hero-logo-img:hover {
    filter: grayscale(0%);
    opacity: 1;
  }
  
  :global(html.dark) .hero-logo-img {
    filter: grayscale(100%) invert(1) brightness(1.2);
    opacity: 0.55;
  }
  
  :global(html.dark) .hero-logo-img:hover {
    filter: grayscale(0%) invert(0) brightness(1);
    opacity: 1;
  }

  /* Facing on side effect for the strip */
  .mask-horizontal {
    perspective: 2000px;
    mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
    -webkit-overflow-scrolling: touch;
  }

  .no-scrollbar::-webkit-scrollbar {
    display: none;
  }
  .no-scrollbar {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  
  .logo-perspective-container {
    transform-style: preserve-3d;
    transform: rotateY(-10deg) rotateX(1deg);
    padding: 1rem 0;
  }
  
  .animate-infinite-scroll {
    transform-style: preserve-3d;
    animation: infinite-scroll 35s linear infinite;
  }
</style>

<script>
  const scrollContainer = document.querySelector('.mask-horizontal') as HTMLElement;
  let isDown = false;
  let startX: number;
  let scrollLeft: number;

  if (scrollContainer) {
    scrollContainer.addEventListener('mousedown', (e) => {
      isDown = true;
      scrollContainer.classList.add('cursor-grabbing');
      startX = e.pageX - scrollContainer.offsetLeft;
      scrollLeft = scrollContainer.scrollLeft;
    });

    scrollContainer.addEventListener('mouseleave', () => {
      isDown = false;
      scrollContainer.classList.remove('cursor-grabbing');
    });

    scrollContainer.addEventListener('mouseup', () => {
      isDown = false;
      scrollContainer.classList.remove('cursor-grabbing');
    });

    scrollContainer.addEventListener('mousemove', (e) => {
      if (!isDown) return;
      e.preventDefault();
      const x = e.pageX - scrollContainer.offsetLeft;
      const walk = (x - startX) * 2;
      scrollContainer.scrollLeft = scrollLeft - walk;
    });
  }
</script>
