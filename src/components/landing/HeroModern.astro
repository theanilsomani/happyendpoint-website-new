---
import { Icon } from 'astro-icon/components';

interface ApiCard {
  title: string;
  icon: string;
  color: string;
}

const row1 = [
  { title: 'Cloudflare Bypass', icon: 'lucide:shield-check', color: 'bg-orange-500' },
  { title: 'Brave Search', icon: 'lucide:compass', color: 'bg-blue-500' },
  { title: 'Best Buy Search', icon: 'lucide:shopping-bag', color: 'bg-blue-600' },
  { title: 'Audible Search', icon: 'lucide:headphones', color: 'bg-yellow-500' },
];
const row2 = [
  { title: 'Google Maps', icon: 'lucide:map-pin', color: 'bg-green-500' },
  { title: 'LinkedIn Job Suggest', icon: 'lucide:linkedin', color: 'bg-blue-700' },
  { title: 'Email Verification', icon: 'lucide:mail-check', color: 'bg-indigo-500' },
  { title: 'TikTok Video', icon: 'lucide:music', color: 'bg-pink-500' },
];
const row3 = [
  { title: 'Amazon Product', icon: 'lucide:shopping-cart', color: 'bg-yellow-500' },
  { title: 'Disposable Email', icon: 'lucide:shield-off', color: 'bg-purple-600' },
  { title: 'Real Estate Data', icon: 'lucide:home', color: 'bg-emerald-500' },
  { title: 'Youtube Video', icon: 'lucide:youtube', color: 'bg-red-500' },
];
const row4 = [
  { title: 'Weibo Search', icon: 'lucide:message-circle', color: 'bg-yellow-600' },
  { title: 'Pinterest User Info', icon: 'lucide:users', color: 'bg-pink-600' },
  { title: 'AI Content', icon: 'lucide:bot', color: 'bg-violet-500' },
  { title: 'X Data', icon: 'lucide:twitter', color: 'bg-sky-500' },
];

interface PlatformLogo {
  name: string;
  /** URL-encoded path under /companies-logo/ — encode '&' and "'" so HTML+browsers stay happy. */
  src: string;
}

const platformLogos: PlatformLogo[] = [
  { name: 'Bayut',           src: '/companies-logo/Bayut_logo.svg' },
  { name: 'Property Finder', src: '/companies-logo/Property_Finder_logo.svg' },
  { name: 'Fotocasa',        src: '/companies-logo/Logo_Fotocasa.svg' },
  { name: 'Tesco',           src: '/companies-logo/Tesco_Logo.svg' },
  { name: 'Sephora',         src: '/companies-logo/Sephora_logo.svg' },
  { name: 'IKEA',            src: '/companies-logo/Ikea_logo.svg' },
  { name: 'H&M',             src: '/companies-logo/HM-Logo.svg' },
  { name: "Kohl's",          src: '/companies-logo/Kohl%27s_logo.svg' },
  { name: 'Priceline',       src: '/companies-logo/Priceline_logo.svg' },
  { name: 'Morningstar',     src: '/companies-logo/Morningstar_Logo.svg' },
  { name: 'Klarna',     src: '/companies-logo/Klarna_logo.svg' },
];
---

<section class="relative overflow-hidden bg-background pt-20 pb-12 lg:pt-24 lg:pb-16">
  <!-- Decorative background elements -->
  <div class="absolute inset-0 -z-10 bg-grid-pattern [mask-image:radial-gradient(ellipse_at_center,transparent_20%,black)] opacity-20 dark:opacity-40"></div>
  <div class="absolute top-0 right-0 -z-10 h-[500px] w-[500px] bg-brand-500/10 blur-[120px] rounded-full translate-x-1/2 -translate-y-1/2"></div>

  <div class="container relative">
    <div class="grid gap-12 lg:grid-cols-2 lg:items-center">
      <!-- Content column -->
      <div class="flex flex-col items-center text-center lg:items-start lg:text-left">
        <div class="flex flex-wrap items-center justify-center lg:justify-start gap-3 animate-fade-in">
          <span class="inline-flex items-center gap-1.5 rounded-full border border-border bg-card/50 backdrop-blur-sm px-3 py-1 text-xs font-medium text-foreground-secondary shadow-sm">
            <span class="text-amber-400 text-sm">★</span> 5.0 rating
          </span>
          <span class="inline-flex items-center gap-1.5 rounded-full border border-border bg-card/50 backdrop-blur-sm px-3 py-1 text-xs font-medium text-foreground-secondary shadow-sm">
            <Icon name="lucide:users" class="h-3.5 w-3.5 text-brand-500" /> 1k+ API community
          </span>
        </div>

        <h1 class="mt-7 text-4xl font-bold tracking-tight text-foreground sm:text-5xl lg:text-5xl xl:text-6xl animate-slide-up">
          Web scraping, made <span class="text-brand-600">easy</span> with APIs
        </h1>

        <p class="mt-5 max-w-xl text-lg text-foreground-secondary animate-slide-up delay-1">
          Get onboard the #1 platform enabling forward-thinking companies to leverage the full potential of web data through +50 ready-to-use scraping APIs.
        </p>

        <div class="mt-9 flex flex-col sm:flex-row items-center gap-4 w-full sm:w-auto animate-slide-up delay-2">
          <a
            href="/library"
            class="group inline-flex items-center justify-center gap-2 w-full sm:w-auto rounded-lg bg-brand-700 px-7 py-3.5 text-sm font-semibold text-white shadow-lg shadow-brand-700/10 transition-all hover:bg-brand-800 hover:shadow-xl hover:shadow-brand-700/20 hover:scale-[1.02] active:scale-[0.98]"
          >
            Get started — For free
            <Icon name="lucide:arrow-right" class="h-4 w-4 transition-transform group-hover:translate-x-1" />
          </a>
          <a
            href="/library"
            class="inline-flex items-center justify-center gap-2 w-full sm:w-auto rounded-lg border border-border bg-card px-7 py-3.5 text-sm font-semibold text-foreground transition-all hover:bg-secondary hover:translate-y-[-1px] hover:shadow-md active:scale-[0.98]"
          >
            <Icon name="lucide:layout-grid" class="h-4 w-4" />
            Browse API library
          </a>
        </div>
      </div>

      <!-- Right content: API Cloud -->
      <div class="relative hidden lg:block animate-fade-in delay-3" aria-hidden="true">
        <div class="relative flex h-[350px] flex-col gap-4 justify-center overflow-hidden [mask-image:radial-gradient(ellipse_at_center,black_30%,transparent_70%)] opacity-90">
          
          <!-- Row 1 -->
          <div class="flex gap-4 justify-center -translate-x-8">
            {row1.map((card, idx) => (
              <div class="group flex items-center gap-2.5 rounded-full border border-border bg-card px-3.5 py-2 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-md cursor-default shrink-0">
                <div class={`flex h-6 w-6 shrink-0 items-center justify-center rounded-full ${card.color} text-white shadow-inner`}>
                  <Icon name={card.icon} class="h-3.5 w-3.5" />
                </div>
                <span class="text-xs font-semibold text-foreground whitespace-nowrap">{card.title}</span>
              </div>
            ))}
          </div>

          <!-- Row 2 -->
          <div class="flex gap-4 justify-center translate-x-4">
            {row2.map((card, idx) => (
              <div class="group flex items-center gap-2.5 rounded-full border border-border bg-card px-3.5 py-2 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-md cursor-default shrink-0">
                <div class={`flex h-6 w-6 shrink-0 items-center justify-center rounded-full ${card.color} text-white shadow-inner`}>
                  <Icon name={card.icon} class="h-3.5 w-3.5" />
                </div>
                <span class="text-xs font-semibold text-foreground whitespace-nowrap">{card.title}</span>
              </div>
            ))}
          </div>

          <!-- Row 3 -->
          <div class="flex gap-4 justify-center -translate-x-12">
            {row3.map((card, idx) => (
              <div class="group flex items-center gap-2.5 rounded-full border border-border bg-card px-3.5 py-2 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-md cursor-default shrink-0">
                <div class={`flex h-6 w-6 shrink-0 items-center justify-center rounded-full ${card.color} text-white shadow-inner`}>
                  <Icon name={card.icon} class="h-3.5 w-3.5" />
                </div>
                <span class="text-xs font-semibold text-foreground whitespace-nowrap">{card.title}</span>
              </div>
            ))}
          </div>

          <!-- Row 4 -->
          <div class="flex gap-4 justify-center translate-x-8">
            {row4.map((card, idx) => (
              <div class="group flex items-center gap-2.5 rounded-full border border-border bg-card px-3.5 py-2 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-md cursor-default shrink-0">
                <div class={`flex h-6 w-6 shrink-0 items-center justify-center rounded-full ${card.color} text-white shadow-inner`}>
                  <Icon name={card.icon} class="h-3.5 w-3.5" />
                </div>
                <span class="text-xs font-semibold text-foreground whitespace-nowrap">{card.title}</span>
              </div>
            ))}
          </div>

        </div>

        <!-- Floating decorative icons -->
        <div class="absolute -top-4 -right-4 animate-pulse text-brand-500/10 pointer-events-none">
          <Icon name="lucide:code-2" class="h-20 w-20 rotate-12" />
        </div>
        <div class="absolute -bottom-8 left-0 animate-pulse text-primary/10 delay-1000 pointer-events-none">
          <Icon name="lucide:database" class="h-24 w-24 -rotate-12" />
        </div>
      </div>
    </div>

    <!-- Platform logos: muted, monochrome, hover restores brand colours.
         Left-aligned on desktop to match the rest of the homepage's section titles. -->
    <div class="mt-14 lg:mt-20 animate-fade-in delay-3">
      <p class="text-center text-xs font-semibold uppercase tracking-widest text-foreground-muted lg:text-left">
        Data from platforms you know
      </p>
      <ul class="hero-logos mt-6 flex flex-wrap items-center justify-center gap-x-6 gap-y-6 sm:gap-x-10 lg:justify-start">
        {platformLogos.map(logo => (
          <li class="flex items-center justify-center w-[110px] h-[40px]">
            <img
              src={logo.src}
              alt={`${logo.name} logo`}
              loading="lazy"
              decoding="async"
              class="max-h-full max-w-full object-contain"
            />
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>

<style>
  .perspective-1000 {
    perspective: 1000px;
  }

  /* Mute the logos with grayscale + lower opacity so they read as a calm
     "trust" strip; restore on hover to preserve brand recognisability. */
  .hero-logos img {
    filter: grayscale(100%);
    opacity: 0.55;
    transition: filter 0.2s ease, opacity 0.2s ease;
  }
  .hero-logos img:hover {
    filter: grayscale(0%);
    opacity: 1;
  }
  :global(html.dark) .hero-logos img {
    filter: grayscale(100%) invert(1);
    opacity: 0.7;
  }
  :global(html.dark) .hero-logos img:hover {
    filter: grayscale(0%) invert(0);
    opacity: 1;
  }
</style>
