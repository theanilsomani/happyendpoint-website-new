---
/**
 * MarketingLayout
 * Layout wrapper for marketing pages with floating capsule header
 * Uses Header shape="floating" for a distinctive visual identity
 */
import BaseLayout from './BaseLayout.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import siteConfig from '@/config/site.config';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  imageAlt?: string;
  noindex?: boolean;
  nofollow?: boolean;
  includeOrgSchema?: boolean;
  canonical?: string;
}

const {
  title,
  description,
  image,
  imageAlt,
  noindex = false,
  nofollow = false,
  includeOrgSchema = false,
  canonical,
} = Astro.props;

const socialLinks = [
  siteConfig.social?.twitter && { platform: 'twitter', href: siteConfig.social.twitter, label: 'Follow on X' },
  siteConfig.social?.github && { platform: 'github', href: siteConfig.social.github, label: 'GitHub' },
].filter(Boolean) as { platform: string; href: string; label: string }[];

const hasAnnouncement = Astro.slots.has('announcement');
---

<BaseLayout
  title={title}
  description={description}
  image={image}
  imageAlt={imageAlt}
  noindex={noindex}
  nofollow={nofollow}
  includeOrgSchema={includeOrgSchema}
  canonical={canonical}
  bodyClass={hasAnnouncement ? 'has-announcement-bar' : undefined}
>
  <div id="nav-container" class="sticky top-0 left-0 right-0 z-50">
    {hasAnnouncement && (
      <div id="announcement-wrapper">
        <slot name="announcement" />
      </div>
    )}

    <Header
      slot="header"
      shape="bar"
      variant="solid"
      position="static"
      colorScheme="default"
      showLanguageSwitcher={false}
      showCta={false}
      cta={{ label: 'Start a Project', href: '/contact' }}
      showScrollProgress
    />
  </div>

  <slot />

  <Footer slot="footer" layout="premium" background="default" showPreFooter={true} socialLinks={socialLinks} />
</BaseLayout>



