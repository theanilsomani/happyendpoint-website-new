---
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import Breadcrumbs from '@/components/he/Breadcrumbs.astro';
import { Icon } from 'astro-icon/components';
import siteConfig from '@/config/site.config';
---

<MarketingLayout
  title="Contact"
  description="Get in touch about API access, dataset requests, custom scraping projects, or partnership opportunities."
>
  <Breadcrumbs items={[{ label: 'Home', href: '/' }, { label: 'Contact' }]} />

  <section class="container max-w-5xl py-12 md:py-16">
    <header class="max-w-2xl">
      <h1 class="text-3xl font-bold text-foreground md:text-4xl">Get in touch</h1>
      <p class="mt-3 text-lg text-foreground-secondary">
        Questions about an API, a dataset request, or something custom? Drop us a line.
      </p>
    </header>

    <div class="mt-10 grid gap-10 lg:grid-cols-[1fr_300px]">
      <!-- Form -->
      <form id="contact-form" class="rounded-lg border border-border bg-card p-6 md:p-8" autocomplete="on">
        <div class="grid gap-4 md:grid-cols-2">
          <label class="block">
            <span class="text-sm font-medium text-foreground">Name</span>
            <input
              name="name"
              type="text"
              required
              class="mt-1 w-full rounded-md border border-border bg-background px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500"
            />
          </label>
          <label class="block">
            <span class="text-sm font-medium text-foreground">Email</span>
            <input
              name="email"
              type="email"
              required
              class="mt-1 w-full rounded-md border border-border bg-background px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500"
            />
          </label>
        </div>
        <label class="mt-4 block">
          <span class="text-sm font-medium text-foreground">Subject</span>
          <select
            name="subject"
            class="mt-1 w-full rounded-md border border-border bg-background px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500"
          >
            <option>General inquiry</option>
            <option>API support</option>
            <option>Dataset request</option>
            <option>Custom scraping project</option>
            <option>Partnership</option>
            <option>Other</option>
          </select>
        </label>
        <label class="mt-4 block">
          <span class="text-sm font-medium text-foreground">Message</span>
          <textarea
            name="message"
            rows="6"
            required
            class="mt-1 w-full rounded-md border border-border bg-background px-3 py-2 text-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500"
          ></textarea>
        </label>

        <!-- Honeypot -->
        <input type="text" name="website" tabindex="-1" autocomplete="off" class="absolute left-[-9999px] h-0 w-0 opacity-0" aria-hidden="true" />

        <button
          type="submit"
          class="mt-6 inline-flex items-center gap-2 rounded-md bg-brand-500 px-5 py-2.5 text-sm font-semibold text-white hover:bg-brand-600"
        >
          Send message
          <Icon name="lucide:send" class="h-4 w-4" />
        </button>

        <p id="contact-success" class="mt-4 hidden rounded-md border border-emerald-500/30 bg-emerald-500/5 p-3 text-sm text-foreground">
          Thanks — we've received your note. We'll get back to you within one business day.
        </p>
        <p id="contact-note" class="mt-4 text-xs text-foreground-muted">
          We'll get back to you within one business day. Messages go straight to our team.
        </p>
      </form>

      <!-- Alternatives sidebar -->
      <aside class="space-y-4">
        <div class="rounded-lg border border-border bg-card p-5">
          <h2 class="text-sm font-semibold uppercase tracking-wider text-foreground-muted">Other ways</h2>
          <ul class="mt-4 space-y-3 text-sm">
            <li class="flex gap-3">
              <Icon name="lucide:mail" class="mt-0.5 h-4 w-4 shrink-0 text-brand-600" />
              <a href={`mailto:${siteConfig.email}`} class="text-foreground hover:text-brand-600 break-all">{siteConfig.email}</a>
            </li>
            <li class="flex gap-3">
              <Icon name="lucide:external-link" class="mt-0.5 h-4 w-4 shrink-0 text-brand-600" />
              <a href="https://rapidapi.com/user/happyendpoint" target="_blank" rel="noopener" class="text-foreground hover:text-brand-600">
                Our RapidAPI profile
              </a>
            </li>
            <li class="flex gap-3">
              <Icon name="lucide:file-text" class="mt-0.5 h-4 w-4 shrink-0 text-brand-600" />
              <a href="https://docs.happyendpoint.com" class="text-foreground hover:text-brand-600">API documentation</a>
            </li>
          </ul>
        </div>
        <div class="rounded-lg border border-border bg-background-secondary p-5 text-sm text-foreground-secondary">
          <p class="font-semibold text-foreground">Looking for a platform we don't cover?</p>
          <p class="mt-2">Tell us which and why — we add new platforms based on demand.</p>
        </div>
      </aside>
    </div>
  </section>

  <script is:inline>
    (function () {
      const form = document.getElementById('contact-form');
      if (!form) return;
      form.addEventListener('submit', function (e) {
        e.preventDefault();
        const honeypot = form.querySelector('input[name="website"]');
        if (honeypot && honeypot.value) return; // silently drop bot submissions
        // Backend deferred — show success UX; real send wired up once provider is chosen.
        form.reset();
        const ok = document.getElementById('contact-success');
        const note = document.getElementById('contact-note');
        if (ok) ok.classList.remove('hidden');
        if (note) note.classList.add('hidden');
      });
    })();
  </script>
</MarketingLayout>
