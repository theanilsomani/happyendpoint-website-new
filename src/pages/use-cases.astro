---
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import Breadcrumbs from '@/components/he/Breadcrumbs.astro';
import { Icon } from 'astro-icon/components';

const useCases = [
  {
    icon: 'lucide:building-2',
    title: 'Property search and alerts',
    industry: 'Real Estate',
    body: 'Build a property search app or alerting service on top of live listings from PropertyFinder, Bayut, Rightmove, Fotocasa, or UAE Real Estate APIs. Filter by price, bedrooms, area, and surface fresh listings the moment they appear.',
    cta: { label: 'See real-estate APIs', href: '/categories/real-estate' },
  },
  {
    icon: 'lucide:trending-up',
    title: 'Price monitoring & competitive intelligence',
    industry: 'Retail / Fashion / Grocery',
    body: 'Track pricing, stock, promotions, and assortment changes across Tesco, H&M, Kohl\'s, Ikea, Sephora, and more. Build internal dashboards or power pricing-engine products.',
    cta: { label: 'See retail APIs', href: '/categories/retail' },
  },
  {
    icon: 'lucide:plane',
    title: 'Travel aggregation',
    industry: 'Travel',
    body: 'Source hotel inventory, rates, and availability from Priceline and partner platforms. Build meta-search, corporate travel tools, or analytics for revenue-management teams.',
    cta: { label: 'See travel APIs', href: '/categories/travel' },
  },
  {
    icon: 'lucide:bar-chart-3',
    title: 'Market analytics & reporting',
    industry: 'Finance',
    body: 'Historical and real-time data for equity research, ETF tracking, and quantitative signals. Back-test strategies with the Morningstar dataset or plug the API into live dashboards.',
    cta: { label: 'See finance APIs', href: '/categories/finance' },
  },
  {
    icon: 'lucide:brain',
    title: 'AI / ML training data',
    industry: 'Any category',
    body: 'Use structured datasets (property listings, product catalogs, hotel inventory) as training or fine-tuning data for domain-specific models. Schema is consistent across snapshots.',
    cta: { label: 'Browse datasets', href: '/datasets' },
  },
  {
    icon: 'lucide:line-chart',
    title: 'Investment research',
    industry: 'Finance / Real Estate',
    body: 'PE firms, hedge funds, and consultancies use our snapshots to benchmark market saturation, pricing trends, and consumer behaviour. Bulk formats (CSV/Parquet) for easy ingestion.',
    cta: { label: 'Talk to us', href: '/contact' },
  },
];
---

<MarketingLayout
  title="Use cases"
  description="Common applications of Happy Endpoint APIs and datasets — property search, price monitoring, travel aggregation, market analytics, AI training data, and investment research."
>
  <Breadcrumbs items={[{ label: 'Home', href: '/' }, { label: 'Use cases' }]} />

  <section class="container py-12 md:py-16">
    <header class="max-w-2xl">
      <h1 class="text-3xl font-bold text-foreground md:text-4xl">What teams build with Happy Endpoint</h1>
      <p class="mt-3 text-lg text-foreground-secondary">
        Six recurring patterns we see across customers. If yours isn't listed, <a href="/contact" class="text-brand-600 underline">tell us about it</a>.
      </p>
    </header>

    <div class="mt-12 grid gap-6 md:grid-cols-2">
      {useCases.map(uc => (
        <article class="flex flex-col gap-4 rounded-lg border border-border bg-card p-6">
          <div class="flex items-start gap-4">
            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-md bg-brand-500/10 text-brand-600">
              <Icon name={uc.icon} class="h-5 w-5" />
            </div>
            <div>
              <p class="text-xs font-semibold uppercase tracking-widest text-brand-600">{uc.industry}</p>
              <h2 class="mt-1 text-lg font-semibold text-foreground">{uc.title}</h2>
            </div>
          </div>
          <p class="text-sm text-foreground-secondary">{uc.body}</p>
          <a href={uc.cta.href} class="mt-auto text-sm font-semibold text-brand-600 hover:underline">
            {uc.cta.label} &rarr;
          </a>
        </article>
      ))}
    </div>
  </section>
</MarketingLayout>
