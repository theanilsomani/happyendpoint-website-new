---
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import EntityHero from '@/components/he/EntityHero.astro';
import EntityCard from '@/components/he/EntityCard.astro';
import EntityGrid from '@/components/he/EntityGrid.astro';
import Breadcrumbs from '@/components/he/Breadcrumbs.astro';
import FAQSection from '@/components/he/FAQSection.astro';
import FreeSampleBlock from '@/components/he/FreeSampleBlock.astro';
import PricingCard from '@/components/he/PricingCard.astro';
import InfoCard from '@/components/he/InfoCard.astro';
import JsonLd from '@/components/seo/JsonLd.astro';
import { Icon } from 'astro-icon/components';
import { getCollection, render } from 'astro:content';
import {
  getPlatformBySlug,
  getCategoryBySlug,
  getApisForPlatform,
  getDatasetsForPlatform,
} from '@/lib/content-queries';
import { datasetSchema } from '@/lib/schema-ld';
import type { Thing, WithContext } from 'schema-dts';

export async function getStaticPaths() {
  const datasets = await getCollection('datasets');
  return datasets.map(d => ({ params: { slug: d.id } }));
}

const { slug } = Astro.params;
const allDatasets = await getCollection('datasets');
const dataset = allDatasets.find(d => d.id === slug);
if (!dataset) return Astro.redirect('/404');

const { Content } = await render(dataset);

const platform = await getPlatformBySlug(dataset.data.platform);
const category = platform ? await getCategoryBySlug(platform.data.category) : undefined;
const apis = platform ? await getApisForPlatform(platform.id) : [];
const platformDatasets = platform ? await getDatasetsForPlatform(platform.id) : [];
const relatedDatasets = platformDatasets.filter(d => d.id !== dataset.id).slice(0, 3);
const apiCounterpart = apis[0]; // the canonical API for this platform

const hasInlineSample = dataset.data.freeSample !== undefined;
const isFreeItself = dataset.data.price.toLowerCase() === 'free';

const faqs = [
  {
    question: `What's in the ${dataset.data.name}?`,
    answer: dataset.data.description,
  },
  {
    question: 'What format is the data delivered in?',
    answer: `${dataset.data.format}. Let us know if you need a different format.`,
  },
  {
    question: 'How is the data collected?',
    answer: 'Collected, deduplicated, and sanity-checked through our data pipeline. Refreshed on a regular cadence.',
  },
  {
    question: 'Can I get a sample first?',
    answer: hasInlineSample
      ? 'Yes - a free sample is available in the section below with the exact same schema as the full dataset.'
      : isFreeItself
        ? 'This listing IS the free sample. <a href="/datasets" class="text-brand-600 underline">Browse paid datasets</a> for the full version.'
        : 'Contact us via the <a href="/contact" class="text-brand-600 underline">contact page</a> to request a sample.',
  },
];

const jsonLd = datasetSchema(dataset, platform) as WithContext<Thing>;

// Logo Mapping Helper
const getPlatformLogo = (id: string) => {
  const mapping: Record<string, string> = {
    'bayut': '/companies-logo/Bayut_logo.svg',
    'propertyfinder': '/companies-logo/Property_Finder_logo.svg',
    'fotocasa': '/companies-logo/Logo_Fotocasa.svg',
    'hm': '/companies-logo/HM-Logo.svg',
    'ikea': '/companies-logo/Ikea_logo.svg',
    'klarna': '/companies-logo/Klarna_logo.svg',
    'morningstar': '/companies-logo/Morningstar_Logo.svg',
    'priceline': '/companies-logo/Priceline_logo.svg',
    'sephora': '/companies-logo/Sephora_logo.svg',
    'tesco': '/companies-logo/Tesco_Logo.svg',
    'kohls': '/companies-logo/Kohl\'s_logo.svg',
    'rightmove': '/companies-logo/Rightmove_Logo.svg', // Fallback
  };
  return mapping[id] || undefined;
};
---

<MarketingLayout
  title={dataset.data.seoTitle ?? (platform ? `${dataset.data.name} - ${platform.data.name} Dataset` : dataset.data.name)}
  description={dataset.data.description}
  image={`/og/datasets/${slug}.png`}
  noindex={dataset.data.noindex}
  canonical={dataset.data.canonical}
>

  <Breadcrumbs items={[
    { label: 'Home', href: '/' },
    { label: 'Datasets', href: '/datasets' },
    { label: dataset.data.name },
  ]} />

  <EntityHero
    eyebrow="Dataset"
    title={dataset.data.name}
    tagline={dataset.data.description}
    logoUrl={platform ? getPlatformLogo(platform.id) : undefined}
    badges={[
      ...(platform ? [platform.data.name] : []),
    ]}
    primaryCta={isFreeItself
      ? { label: 'Get Free Dataset', href: '/contact', external: false }
      : { label: 'Purchase Dataset', href: '/contact', external: false }}
  >
    <div slot="right" class="flex flex-col gap-6 w-full lg:min-w-[280px]">
      <div class="space-y-3">
        <h3 class="text-[10px] font-bold uppercase tracking-[0.2em] text-foreground-muted">Dataset Details</h3>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-4 text-xs border-t border-border/50 pt-3">

          <div>
            <p class="text-foreground-muted font-medium">Records</p>
            <p class="text-foreground font-bold mt-0.5">{dataset.data.recordCount}</p>
          </div>
          <div>
            <p class="text-foreground-muted font-medium">Freshness</p>
            <p class="text-foreground font-bold mt-0.5">Weekly Snapshot</p>
          </div>
          <div>
            <p class="text-foreground-muted font-medium">Format</p>
            <p class="text-foreground font-bold mt-0.5">{dataset.data.format}</p>
          </div>
          <div>
            <p class="text-foreground-muted font-medium">Platform</p>
            <p class="text-foreground font-bold mt-0.5">{platform?.data.name ?? 'Happy Endpoint'}</p>
          </div>
          <div>
            <p class="text-foreground-muted font-medium">Delivery</p>
            <p class="text-foreground font-bold mt-0.5">Instant Download</p>
          </div>
          <div>
            <p class="text-foreground-muted font-medium">Support</p>
            <p class="text-foreground font-bold mt-0.5">Expert Email</p>
          </div>
        </div>
      </div>

      {apiCounterpart && (
        <div class="space-y-3">
          <h3 class="text-[10px] font-bold uppercase tracking-[0.2em] text-foreground-muted">Live Access</h3>
          <div class="space-y-2">
            <a href={`/library/${apiCounterpart.id}`} class="group flex items-center justify-between gap-3 p-2 rounded-lg border border-border bg-brand-500/[0.02] hover:bg-brand-500/[0.05] transition-colors">
              <div class="min-w-0">
                <p class="text-xs font-bold text-foreground truncate">{apiCounterpart.data.name}</p>
                <p class="text-[9px] uppercase tracking-wider text-foreground-muted">REST API</p>
              </div>
              <Icon name="lucide:webhook" class="h-3.5 w-3.5 text-foreground-muted group-hover:text-brand-600 transition-colors" />
            </a>
          </div>
        </div>
      )}
    </div>
  </EntityHero>

  <div class="container py-12 md:py-16">
    <div class="grid gap-16 lg:grid-cols-[1fr_320px]">
      
      <!-- Sidebar (Moves to top on mobile) -->
      <aside class="space-y-12 order-first lg:order-last">
        <!-- Pricing Card -->
        <PricingCard pricing={dataset.data.price} variant="dataset" isFree={isFreeItself} purchaseUrl={dataset.data.purchaseUrl} />
      </aside>

      <!-- Main Content -->
      <div class="space-y-24 order-last lg:order-first">
        <!-- Overview / Long Description -->
        <section id="overview">
          <h2 class="text-2xl font-bold tracking-tight text-foreground mb-8">Overview</h2>
          <article class="prose max-w-none prose-p:text-lg prose-p:leading-relaxed prose-headings:text-foreground">
            <Content />
          </article>
        </section>

        <!-- Features / What's in the dataset -->
        {dataset.data.features.length > 0 && (
          <section id="features">
            <h2 class="text-2xl font-bold tracking-tight text-foreground mb-8">What's in this dataset</h2>
            <div class="grid gap-6 sm:grid-cols-2">
              {dataset.data.features.map(f => (
                <div class="flex items-start gap-4 p-2">
                  <div class="mt-1 flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-brand-500/10">
                    <Icon name="lucide:check" class="h-3.5 w-3.5 text-brand-600" />
                  </div>
                  <span class="text-base font-medium leading-relaxed text-foreground-secondary">{f}</span>
                </div>
              ))}
            </div>
          </section>
        )}

        <!-- Free Sample Block -->
        {dataset.data.freeSample && (
          <section id="sample" class="rounded-3xl border border-border bg-card p-10 md:p-12 shadow-sm">
            <FreeSampleBlock
              heading="Download a free sample"
              sampleName={dataset.data.freeSample.name}
              recordCount={dataset.data.freeSample.recordCount}
              format={dataset.data.freeSample.format}
              downloadUrl={dataset.data.freeSample.downloadUrl}
            />
          </section>
        )}

        <!-- FAQ -->
        <section id="faq" class="pt-12 border-t border-border">
          <FAQSection faqs={faqs} isNested={true} />
        </section>
      </div>
    </div>
  </div>


  {relatedDatasets.length > 0 && (
    <section class="border-t border-border py-24 bg-background">
      <div class="container">
        <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-12">
          <div>
            <h2 class="text-3xl font-bold tracking-tight text-foreground">More from {platform?.data.name ?? 'this platform'}</h2>
            <p class="mt-2 text-foreground-secondary text-lg">Browse other snapshots and data formats available for this source.</p>
          </div>
          <a href="/datasets" class="group flex items-center gap-2 text-sm font-bold text-brand-600">
            View all datasets 
            <Icon name="lucide:arrow-right" class="h-4 w-4 transition-transform group-hover:translate-x-1" />
          </a>
        </div>
        <EntityGrid columns={2}>
          {relatedDatasets.map(d => (
            <EntityCard
              variant="dataset"
              title={d.data.name}
              href={`/datasets/${d.id}`}
              description={d.data.description}
              metrics={[
                { label: 'Records', value: d.data.recordCount },
                { label: 'Format', value: d.data.format },
              ]}
              badge={d.data.price.toLowerCase() === 'free' ? 'Free' : undefined}
              tags={d.data.tags}
            />
          ))}
        </EntityGrid>
      </div>
    </section>
  )}
</MarketingLayout>

<JsonLd schema={jsonLd} />
