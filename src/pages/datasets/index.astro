---
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import EntityCard from '@/components/he/EntityCard.astro';
import Breadcrumbs from '@/components/he/Breadcrumbs.astro';
import FilterPanel from '@/components/he/FilterPanel.tsx';
import { getAllPublishedDatasets, getAllPublishedPlatforms, getAllCategories } from '@/lib/content-queries';

const datasets = await getAllPublishedDatasets();
datasets.sort((a, b) => a.data.name.localeCompare(b.data.name));
const platforms = await getAllPublishedPlatforms();
const categories = await getAllCategories();

const platformToCategory = new Map(platforms.map(p => [p.id, p.data.category]));

const facets = [
  {
    key: 'platform',
    label: 'Platform',
    options: platforms
      .filter(p => datasets.some(d => d.data.platform === p.id))
      .map(p => ({ value: p.id, label: p.data.name })),
  },
  {
    key: 'category',
    label: 'Category',
    options: categories.map(c => ({ value: c.id, label: c.data.name })),
  },
];
---

<MarketingLayout
  title="Datasets"
  description="Structured bulk data snapshots across real estate, retail, travel, finance, and more."
>
  <Breadcrumbs items={[{ label: 'Home', href: '/' }, { label: 'Datasets' }]} />

  <section class="container py-10 md:py-14">
    <header class="max-w-2xl">
      <h1 class="text-3xl font-bold text-foreground md:text-4xl">Datasets</h1>
      <p class="mt-3 text-lg text-foreground-secondary">
        One-shot snapshots of the data you need, in the format you need it.
      </p>
    </header>

    <div class="mt-10 grid gap-8 md:grid-cols-[260px_1fr]">
      <FilterPanel client:load facets={facets} heading="Filter datasets" />

      <div data-filter-target>
        <div class="grid gap-4 grid-cols-1 sm:grid-cols-2 lg:grid-cols-3">
          {datasets.map(d => {
            const category = platformToCategory.get(d.data.platform) ?? '';
            const isFree = d.data.price.toLowerCase() === 'free';
            const hasSample = d.data.freeSample !== undefined;
            return (
              <div
                data-entity-card
                data-variant="dataset"
                data-platform={d.data.platform}
                data-category={category}
                data-tags={d.data.tags.join(',')}
                data-search={`${d.data.name} ${d.data.description} ${d.data.features.join(' ')}`.toLowerCase()}
              >
                <EntityCard
                  variant="dataset"
                  title={d.data.name}
                  href={`/datasets/${d.id}`}
                  description={d.data.description}
                  metrics={[
                    { label: 'Records', value: d.data.recordCount },
                    { label: 'Format', value: d.data.format },
                    { label: 'Price', value: d.data.price },
                  ]}
                  badge={isFree ? 'FREE' : hasSample ? 'FREE SAMPLE' : undefined}
                  tags={d.data.tags}
                />
              </div>
            );
          })}
        </div>
      </div>
    </div>
  </section>
</MarketingLayout>
