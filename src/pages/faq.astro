---
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import Breadcrumbs from '@/components/he/Breadcrumbs.astro';
import FAQSection from '@/components/he/FAQSection.astro';

const sections = [
  {
    heading: 'Getting started',
    faqs: [
      { question: 'What is Happy Endpoint?', answer: 'A catalog of APIs and datasets covering the platforms that power real-estate, travel, grocery, finance, retail, fashion, and beauty. Everything is sold on RapidAPI.' },
      { question: 'Do I need to sign up on happyendpoint.com?', answer: 'No. The site is a catalog. Subscriptions, API keys, and billing all live on RapidAPI.' },
      { question: 'How fast can I integrate?', answer: 'Most teams ship in a day. Find the API, subscribe on RapidAPI, drop in the key, start making requests.' },
    ],
  },
  {
    heading: 'Pricing',
    faqs: [
      { question: 'How is pricing structured?', answer: 'APIs use RapidAPI\'s per-request model. Most have free tiers. Datasets are priced per snapshot — see each dataset page for the amount.' },
      { question: 'Is there a free tier?', answer: 'Yes — most APIs include a free tier for testing. Many datasets have <a href="/free-datasets" class="text-brand-600 underline">free samples</a>.' },
      { question: 'Do you offer enterprise plans?', answer: 'Yes — <a href="/contact" class="text-brand-600 underline">contact us</a> for volume pricing or custom agreements.' },
    ],
  },
  {
    heading: 'Data quality & coverage',
    faqs: [
      { question: 'How often is data updated?', answer: 'APIs serve live data on every request. Datasets are refreshed on a schedule — daily or weekly depending on the platform. See each dataset\'s page for details.' },
      { question: 'How accurate is the data?', answer: 'Data is collected, deduplicated, and sanity-checked through our pipeline. We don\'t invent fields — what we publish is what the source platforms expose.' },
      { question: 'Can you add a platform you don\'t cover?', answer: 'Often yes. Tell us which platform and the use case — we prioritise based on demand.' },
    ],
  },
  {
    heading: 'Technical',
    faqs: [
      { question: 'What formats do you support?', answer: 'APIs return JSON. Datasets are delivered in JSON, CSV, or Parquet — choose at purchase time.' },
      { question: 'Where are the docs?', answer: 'Full API documentation lives at <a href="https://docs.happyendpoint.com" class="text-brand-600 underline">docs.happyendpoint.com</a>.' },
      { question: 'Can I self-host?', answer: 'APIs no — they run on our infrastructure via RapidAPI. Datasets yes — once downloaded, they\'re yours to use.' },
    ],
  },
  {
    heading: 'Licensing & legal',
    faqs: [
      { question: 'Can I use this data commercially?', answer: 'Yes, subject to the plan you subscribe to. Each API\'s RapidAPI listing shows the terms for that tier.' },
      { question: 'Is scraping legal?', answer: 'Collecting publicly available data is generally permissible in most jurisdictions, though specific terms depend on your use case and location. We recommend reviewing platform terms of service for your intended application.' },
      { question: 'Do you store personal data?', answer: 'We do not target personal information. Any incidental PII in collected datasets (e.g. public listing contact) is handled per our <a href="/privacy" class="text-brand-600 underline">privacy policy</a>.' },
    ],
  },
];
---

<MarketingLayout
  title="Frequently asked questions"
  description="Answers about Happy Endpoint's APIs, datasets, pricing, data quality, and licensing."
>
  <Breadcrumbs items={[{ label: 'Home', href: '/' }, { label: 'FAQ' }]} />

  <section class="container max-w-3xl py-12 md:py-16">
    <h1 class="text-3xl font-bold text-foreground md:text-4xl">Frequently asked questions</h1>
    <p class="mt-3 text-lg text-foreground-secondary">
      Everything you might wonder before subscribing.
    </p>
  </section>

  {sections.map(section => (
    <FAQSection title={section.heading} faqs={section.faqs} />
  ))}
</MarketingLayout>
