---
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import Breadcrumbs from '@/components/he/Breadcrumbs.astro';
import { getAllPublishedPlatforms, getAllPublishedApis, getAllPublishedDatasets } from '@/lib/content-queries';
import { Icon } from 'astro-icon/components';

const [platforms, apis, datasets] = await Promise.all([
  getAllPublishedPlatforms(),
  getAllPublishedApis(),
  getAllPublishedDatasets(),
]);
---

<MarketingLayout
  title="About Happy Endpoint"
  description="Happy Endpoint builds and sells APIs and datasets for the platforms that drive industry — real estate, travel, grocery, finance, retail, fashion, and beauty."
>
  <Breadcrumbs items={[{ label: 'Home', href: '/' }, { label: 'About' }]} />

  <section class="container py-12 md:py-16">
    <header class="max-w-3xl">
      <p class="text-xs font-semibold uppercase tracking-widest text-brand-600">About us</p>
      <h1 class="mt-2 text-3xl font-bold text-foreground md:text-5xl">Data infrastructure for builders who don't want to build scrapers</h1>
      <p class="mt-5 text-lg text-foreground-secondary">
        Happy Endpoint turns the public data on the internet's biggest platforms into clean, documented APIs and structured datasets — sold on RapidAPI, backed by free samples, delivered in formats you can ship with.
      </p>
    </header>

    <div class="mt-12 grid gap-6 md:grid-cols-3">
      {[
        { num: platforms.length, label: 'Platforms covered' },
        { num: apis.length, label: 'APIs available' },
        { num: datasets.length, label: 'Datasets available' },
      ].map(stat => (
        <div class="rounded-lg border border-border bg-card p-6">
          <p class="text-4xl font-bold text-brand-600">{stat.num}</p>
          <p class="mt-1 text-sm text-foreground-secondary">{stat.label}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="border-t border-border bg-background-secondary py-12">
    <div class="container max-w-3xl prose">
      <h2>What we do</h2>
      <p>We pick industries where the platforms are obvious, the data is valuable, and building your own scraper would eat a quarter of engineering time. Then we build and maintain the collection, cleaning, and delivery layer so you don't have to.</p>

      <h2>How we sell</h2>
      <p>Every API lives on RapidAPI — that's where you subscribe, manage keys, and track usage. We never gate the catalog; every product on this site links to its RapidAPI listing. Datasets are priced per snapshot and either downloaded directly or delivered over secure links.</p>

      <h2>Our philosophy</h2>
      <ul>
        <li><strong>Free samples, always.</strong> If we're selling a dataset, we want you to try the schema first.</li>
        <li><strong>No surprise pricing.</strong> RapidAPI's per-request model is transparent. Datasets are quoted up front.</li>
        <li><strong>Ship it in a week.</strong> Integration should be measured in hours, not sprints.</li>
      </ul>

      <h2>Who we are</h2>
      <p>A small team of engineers and data operators. We focus on keeping the pipelines reliable and the docs current. If you've spotted a gap or need a platform we don't cover, <a href="/contact">tell us about it</a>.</p>
    </div>
  </section>
</MarketingLayout>
