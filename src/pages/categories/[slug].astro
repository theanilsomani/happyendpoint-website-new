---
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import EntityHero from '@/components/he/EntityHero.astro';
import EntityCard from '@/components/he/EntityCard.astro';
import EntityGrid from '@/components/he/EntityGrid.astro';
import Breadcrumbs from '@/components/he/Breadcrumbs.astro';
import FAQSection from '@/components/he/FAQSection.astro';
import { getCollection, render } from 'astro:content';
import {
  getCategoryBySlug,
  getPlatformsInCategory,
  getApisForPlatform,
  getDatasetsForPlatform,
} from '@/lib/content-queries';

export async function getStaticPaths() {
  const categories = await getCollection('categories');
  return categories.map(c => ({ params: { slug: c.id } }));
}

const { slug } = Astro.params;
const category = await getCategoryBySlug(slug!);
if (!category) return Astro.redirect('/404');

const { Content } = await render(category);
const platforms = await getPlatformsInCategory(category.id);

// Collect APIs and datasets across all platforms in this category
const allApis = (await Promise.all(platforms.map(p => getApisForPlatform(p.id)))).flat();
const allDatasets = (await Promise.all(platforms.map(p => getDatasetsForPlatform(p.id)))).flat();

const faqs = [
  {
    question: `What's included in the ${category.data.name} category?`,
    answer: category.data.description,
  },
  {
    question: 'Are free samples available?',
    answer: 'Yes — many datasets in this category ship with free samples you can download without a subscription. See the <a href="/free-datasets" class="text-brand-600 underline">free samples page</a>.',
  },
  {
    question: 'How is pricing structured?',
    answer: 'APIs are sold on RapidAPI with per-request pricing and free tiers. Full datasets are priced per snapshot; contact us for custom scopes.',
  },
];
---

<MarketingLayout
  title={`${category.data.name} APIs & datasets`}
  description={category.data.description}
>
  <Breadcrumbs items={[
    { label: 'Home', href: '/' },
    { label: 'Categories', href: '/categories' },
    { label: category.data.name },
  ]} />

  <EntityHero
    eyebrow="Category"
    title={`${category.data.name} APIs & datasets`}
    tagline={category.data.tagline}
  />

  <article class="container max-w-3xl py-12 prose">
    <Content />
  </article>

  {platforms.length > 0 && (
    <section class="container py-12">
      <h2 class="text-2xl font-bold text-foreground md:text-3xl">Platforms in {category.data.name}</h2>
      <div class="mt-8">
        <EntityGrid columns={3}>
          {platforms.map(p => (
            <EntityCard
              variant="platform"
              title={p.data.name}
              href={`/platforms/${p.id}`}
              description={p.data.tagline}
              metrics={[
                { label: 'Domain', value: p.data.domain },
              ]}
              tags={p.data.tags}
            />
          ))}
        </EntityGrid>
      </div>
    </section>
  )}

  {allApis.length > 0 && (
    <section class="border-t border-border bg-background-secondary py-12">
      <div class="container">
        <h2 class="text-2xl font-bold text-foreground md:text-3xl">APIs in this category</h2>
        <div class="mt-8">
          <EntityGrid columns={3}>
            {allApis.slice(0, 9).map(a => (
              <EntityCard
                variant="api"
                title={a.data.name}
                href={`/library/${a.id}`}
                description={a.data.description}
                tags={a.data.tags}
              />
            ))}
          </EntityGrid>
        </div>
      </div>
    </section>
  )}

  {allDatasets.length > 0 && (
    <section class="container py-12">
      <h2 class="text-2xl font-bold text-foreground md:text-3xl">Datasets in this category</h2>
      <div class="mt-8">
        <EntityGrid columns={3}>
          {allDatasets.slice(0, 9).map(d => (
            <EntityCard
              variant="dataset"
              title={d.data.name}
              href={`/datasets/${d.id}`}
              description={d.data.description}
              metrics={[
                { label: 'Records', value: d.data.recordCount },
                { label: 'Format', value: d.data.format },
              ]}
              badge={d.data.freeSample !== undefined || d.data.price.toLowerCase() === 'free' ? 'FREE SAMPLE' : undefined}
              tags={d.data.tags}
            />
          ))}
        </EntityGrid>
      </div>
    </section>
  )}

  <FAQSection faqs={faqs} />
</MarketingLayout>
