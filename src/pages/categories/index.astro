---
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import EntityCard from '@/components/he/EntityCard.astro';
import EntityGrid from '@/components/he/EntityGrid.astro';
import Breadcrumbs from '@/components/he/Breadcrumbs.astro';
import { getAllCategories, getPlatformsInCategory } from '@/lib/content-queries';

const categories = await getAllCategories();
const enriched = await Promise.all(
  categories.map(async c => ({
    cat: c,
    platformCount: (await getPlatformsInCategory(c.id)).length,
  })),
);
// Sort by order then name
enriched.sort((a, b) => a.cat.data.order - b.cat.data.order || a.cat.data.name.localeCompare(b.cat.data.name));
---

<MarketingLayout
  title="Data categories"
  description="Browse APIs and datasets by industry — real estate, travel, grocery, finance, retail, fashion, and beauty."
>
  <Breadcrumbs items={[{ label: 'Home', href: '/' }, { label: 'Categories' }]} />

  <section class="container py-10 md:py-14">
    <header class="max-w-2xl">
      <h1 class="text-3xl font-bold text-foreground md:text-4xl">Categories</h1>
      <p class="mt-3 text-lg text-foreground-secondary">
        APIs and datasets grouped by industry. Each category covers the leading platforms in that space.
      </p>
    </header>

    <div class="mt-10">
      <EntityGrid columns={3}>
        {enriched.map(({ cat, platformCount }) => (
          <EntityCard
            variant="category"
            title={cat.data.name}
            href={`/categories/${cat.id}`}
            description={cat.data.description}
            metrics={[{ label: 'Platforms', value: String(platformCount) }]}
          />
        ))}
      </EntityGrid>
    </div>
  </section>
</MarketingLayout>
