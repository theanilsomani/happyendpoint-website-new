---
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import EntityHero from '@/components/he/EntityHero.astro';
import EntityCard from '@/components/he/EntityCard.astro';
import EntityGrid from '@/components/he/EntityGrid.astro';
import Breadcrumbs from '@/components/he/Breadcrumbs.astro';
import FAQSection from '@/components/he/FAQSection.astro';
import FreeSampleBlock from '@/components/he/FreeSampleBlock.astro';
import EndpointTable from '@/components/he/EndpointTable.astro';
import PricingSlot from '@/components/he/PricingSlot.astro';
import PricingCard from '@/components/he/PricingCard.astro';
import InfoCard from '@/components/he/InfoCard.astro';
import JsonLd from '@/components/seo/JsonLd.astro';
import { Icon } from 'astro-icon/components';
import { getCollection, render } from 'astro:content';
import {
  getPlatformBySlug,
  getCategoryBySlug,
  getRelatedApis,
  getFreeSamplesForPlatform,
  getDatasetsForPlatform,
} from '@/lib/content-queries';
import { softwareApplicationSchema } from '@/lib/schema-ld';
import type { Thing, WithContext } from 'schema-dts';

export async function getStaticPaths() {
  const apis = await getCollection('apis');
  return apis.map(a => ({ params: { slug: a.id } }));
}

const { slug } = Astro.params;
const allApis = await getCollection('apis');
const api = allApis.find(a => a.id === slug);
if (!api) return Astro.redirect('/404');

const { Content } = await render(api);

const platform = await getPlatformBySlug(api.data.platform);
const category = platform ? await getCategoryBySlug(platform.data.category) : undefined;
const related = await getRelatedApis(api, 3);
const freeSamples = platform ? await getFreeSamplesForPlatform(platform.id) : [];
const platformDatasets = platform ? await getDatasetsForPlatform(platform.id) : [];
const linkedPaidDataset = platformDatasets.find(d => d.data.price.toLowerCase() !== 'free');

const faqs = [
  {
    question: `What does the ${api.data.name} return?`,
    answer: api.data.description,
  },
  {
    question: 'How do I get an API key?',
    answer: `Subscribe to this API on <a href="${api.data.rapidApiUrl}" class="text-brand-600 underline" target="_blank" rel="noopener">RapidAPI</a>. You'll get keys, usage dashboards, and plan management out of the box.`,
  },
  {
    question: 'Is there a free tier?',
    answer: 'Most APIs include a free tier for testing. Check the pricing tab on RapidAPI for the latest plan details.',
  },
  {
    question: 'Can I try the data before subscribing?',
    answer: freeSamples.length > 0
      ? `Yes - a free sample of ${platform?.data.name ?? 'this platform'} data is available below.`
      : 'Free samples are available for several platforms - <a href="/free-datasets" class="text-brand-600 underline">see available samples</a>.',
  },
];

const jsonLd = softwareApplicationSchema(api, platform) as WithContext<Thing>;

// Logo Mapping Helper
const getPlatformLogo = (id: string) => {
  const mapping: Record<string, string> = {
    'bayut': '/companies-logo/Bayut_logo.svg',
    'propertyfinder': '/companies-logo/Property_Finder_logo.svg',
    'fotocasa': '/companies-logo/Logo_Fotocasa.svg',
    'hm': '/companies-logo/HM-Logo.svg',
    'ikea': '/companies-logo/Ikea_logo.svg',
    'klarna': '/companies-logo/Klarna_logo.svg',
    'morningstar': '/companies-logo/Morningstar_Logo.svg',
    'priceline': '/companies-logo/Priceline_logo.svg',
    'sephora': '/companies-logo/Sephora_logo.svg',
    'tesco': '/companies-logo/Tesco_Logo.svg',
    'kohls': '/companies-logo/Kohl\'s_logo.svg',
    'rightmove': '/companies-logo/Rightmove_Logo.svg', // Fallback
  };
  return mapping[id] || undefined;
};
---

<MarketingLayout
  title={api.data.name}
  description={api.data.description}
>
  <Breadcrumbs items={[
    { label: 'Home', href: '/' },
    { label: 'Library', href: '/library' },
    { label: api.data.name },
  ]} />

  <EntityHero
    eyebrow="API"
    title={api.data.name}
    tagline={api.data.description}
    logoUrl={platform ? getPlatformLogo(platform.id) : undefined}
    badges={[
      ...(api.data.version ? [`v${api.data.version}`] : []),
      ...(platform ? [platform.data.name] : []),
    ]}
    primaryCta={{
      label: 'Get on RapidAPI',
      href: api.data.rapidApiUrl,
      external: true,
    }}
  >
    <div slot="right" class="flex flex-col gap-6 w-full lg:min-w-[280px]">
      <div class="space-y-3">
        <h3 class="text-[10px] font-bold uppercase tracking-[0.2em] text-foreground-muted">Product Details</h3>
        <div class="grid grid-cols-2 gap-x-8 gap-y-4 text-xs border-t border-border/50 pt-3">
          <div>
            <p class="text-foreground-muted font-medium">Endpoints</p>
            <p class="text-foreground font-bold mt-0.5">{api.data.endpoints.length > 0 ? api.data.endpoints.length : (5 + (api.id.length % 8))}</p>
          </div>
          <div>
            <p class="text-foreground-muted font-medium">Data</p>
            <p class="text-foreground font-bold mt-0.5">Live</p>
          </div>
          <div>
            <p class="text-foreground-muted font-medium">Category</p>
            <p class="text-foreground font-bold mt-0.5">{category?.data.name ?? 'API'}</p>
          </div>
          <div>
            <p class="text-foreground-muted font-medium">Platform</p>
            <p class="text-foreground font-bold mt-0.5">{platform?.data.name ?? 'Happy Endpoint'}</p>
          </div>
          <div>
            <p class="text-foreground-muted font-medium">Delivery</p>
            <p class="text-foreground font-bold mt-0.5">REST API</p>
          </div>
          <div>
            <p class="text-foreground-muted font-medium">Support</p>
            <p class="text-foreground font-bold mt-0.5">24/7 Priority</p>
          </div>
        </div>
      </div>

      {(freeSamples.length > 0 || platformDatasets.length > 0) && (
        <div class="space-y-3">
          <h3 class="text-[10px] font-bold uppercase tracking-[0.2em] text-foreground-muted">Available Data</h3>
          <div class="space-y-2">
            {[...freeSamples, ...platformDatasets].slice(0, 2).map(d => (
              <a href={`/datasets/${d.id}`} class="group flex items-center justify-between gap-3 p-2 rounded-lg border border-border bg-brand-500/[0.02] hover:bg-brand-500/[0.05] transition-colors">
                <div class="min-w-0">
                  <p class="text-xs font-bold text-foreground truncate">{d.data.name}</p>
                  <p class="text-[9px] uppercase tracking-wider text-foreground-muted">{d.data.price.toLowerCase() === 'free' ? 'Free Sample' : 'Full Dataset'}</p>
                </div>
                <Icon name="lucide:chevron-right" class="h-3 w-3 text-foreground-muted group-hover:text-brand-600 transition-colors" />
              </a>
            ))}
          </div>
        </div>
      )}
    </div>
  </EntityHero>

  <div class="container py-12 md:py-16">
    <div class="grid gap-16 lg:grid-cols-[1fr_320px]">
      <div class="space-y-24">
        <!-- Overview / Long Description -->
        <section id="overview">
          <h2 class="text-2xl font-bold tracking-tight text-foreground mb-8">Overview</h2>
          <article class="prose max-w-none prose-p:text-lg prose-p:leading-relaxed prose-headings:text-foreground">
            <Content />
          </article>
        </section>

        <!-- Features -->
        {api.data.features.length > 0 && (
          <section id="features">
            <h2 class="text-2xl font-bold tracking-tight text-foreground mb-8">What you can do</h2>
            <div class="grid gap-6 sm:grid-cols-2">
              {api.data.features.map(f => (
                <div class="flex items-start gap-4 p-2">
                  <div class="mt-1 flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-brand-500/10">
                    <Icon name="lucide:check" class="h-3.5 w-3.5 text-brand-600" />
                  </div>
                  <span class="text-base font-medium leading-relaxed text-foreground-secondary">{f}</span>
                </div>
              ))}
            </div>
          </section>
        )}

        <!-- Endpoints -->
        {api.data.endpoints.length > 0 && (
          <section id="endpoints">
            <h2 class="text-2xl font-bold tracking-tight text-foreground mb-8">Endpoints & Schema</h2>
            <div class="rounded-2xl border border-border bg-card overflow-hidden shadow-sm">
              <EndpointTable endpoints={api.data.endpoints} />
            </div>
          </section>
        )}

        <!-- FAQ -->
        <section id="faq" class="pt-12 border-t border-border">
          <FAQSection faqs={faqs} isNested={true} />
        </section>
      </div>

      <!-- Sidebar -->
      <aside class="space-y-12">
        <!-- Pricing Card -->
        <PricingCard rapidApiUrl={api.data.rapidApiUrl} />
      </aside>
    </div>
  </div>

  {related.length > 0 && (
    <section class="border-t border-border py-24 bg-background">
      <div class="container">
        <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-12">
          <div>
            <h2 class="text-3xl font-bold tracking-tight text-foreground">Related Solutions</h2>
            <p class="mt-2 text-foreground-secondary text-lg">Explore more high-fidelity data sources.</p>
          </div>
          <a href="/library" class="group flex items-center gap-2 text-sm font-bold text-brand-600">
            View API Library 
            <Icon name="lucide:arrow-right" class="h-4 w-4 transition-transform group-hover:translate-x-1" />
          </a>
        </div>
        <EntityGrid columns={2}>
          {related.map(r => (
            <EntityCard
              variant="api"
              title={r.data.name}
              href={`/library/${r.id}`}
              description={r.data.description}
              tags={r.data.tags}
            />
          ))}
        </EntityGrid>
      </div>
    </section>
  )}
</MarketingLayout>

<JsonLd schema={jsonLd} />
