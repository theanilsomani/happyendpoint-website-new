---
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import EntityCard from '@/components/he/EntityCard.astro';
import Breadcrumbs from '@/components/he/Breadcrumbs.astro';
import FilterPanel from '@/components/he/FilterPanel.tsx';
import { getAllPublishedApis, getAllPublishedPlatforms, getAllCategories } from '@/lib/content-queries';

const apis = await getAllPublishedApis();
apis.sort((a, b) => a.data.name.localeCompare(b.data.name));
const platforms = await getAllPublishedPlatforms();
const categories = await getAllCategories();

// Look-up: platformId -> categorySlug (via platform)
const platformToCategory = new Map(platforms.map(p => [p.id, p.data.category]));

// Collect all unique tags across APIs
const tagSet = new Set<string>();
apis.forEach(a => a.data.tags.forEach(t => tagSet.add(t)));
const allTags = Array.from(tagSet).sort();

const facets = [
  {
    key: 'platform',
    label: 'Platform',
    options: platforms
      .filter(p => apis.some(a => a.data.platform === p.id))
      .map(p => ({ value: p.id, label: p.data.name })),
  },
  {
    key: 'category',
    label: 'Category',
    options: categories.map(c => ({ value: c.id, label: c.data.name })),
  },
  {
    key: 'tag',
    label: 'Tag',
    options: allTags.map(t => ({ value: t, label: t })),
  },
];
---

<MarketingLayout
  title="API Library"
  description="All Happy Endpoint APIs. Live, request-time data from the platforms that matter."
>
  <Breadcrumbs items={[{ label: 'Home', href: '/' }, { label: 'Library' }]} />

  <section class="container py-10 md:py-14">
    <header class="max-w-2xl">
      <h1 class="text-3xl font-bold text-foreground md:text-4xl">API Library</h1>
      <p class="mt-3 text-lg text-foreground-secondary">
        Every Happy Endpoint API. Subscribe on RapidAPI, get live data in minutes.
      </p>
    </header>

    <div class="mt-10 grid gap-8 md:grid-cols-[260px_1fr]">
      <FilterPanel client:load facets={facets} heading="Filter APIs" />

      <div data-filter-target>
        <div class="grid gap-4 grid-cols-1 sm:grid-cols-2 lg:grid-cols-3">
          {apis.map(a => {
            const category = platformToCategory.get(a.data.platform) ?? '';
            return (
              <div
                data-entity-card
                data-variant="api"
                data-platform={a.data.platform}
                data-category={category}
                data-tags={a.data.tags.join(',')}
                data-search={`${a.data.name} ${a.data.description} ${a.data.features.join(' ')}`.toLowerCase()}
              >
                <EntityCard
                  variant="api"
                  title={a.data.name}
                  href={`/library/${a.id}`}
                  description={a.data.description}
                  metrics={a.data.version ? [{ label: 'Version', value: a.data.version }] : []}
                  tags={a.data.tags}
                />
              </div>
            );
          })}
        </div>
      </div>
    </div>
  </section>
</MarketingLayout>
