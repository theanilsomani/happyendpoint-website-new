---
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import { Icon } from 'astro-icon/components';

const oldHost = 'bayut14.p.rapidapi.com';
const newHost = 'uae-real-estate3.p.rapidapi.com';
const newUrl = 'https://rapidapi.com/happyendpoint/api/uae-real-estate3';

const steps = [
  {
    step: '01',
    title: 'Subscribe to New API',
    desc: 'Visit the UAE Real Estate API on RapidAPI and subscribe to your preferred plan (Free tier included).',
    link: newUrl,
    linkLabel: 'Get Started',
  },
  {
    step: '02',
    title: 'Update Host & URL',
    desc: `Replace '${oldHost}' with '${newHost}' in your code and headers.`,
    link: null,
    linkLabel: null,
  },
  {
    step: '03',
    title: 'Test & Deploy',
    desc: 'Run your integration tests to verify the identical data structure, then deploy your changes.',
    link: null,
    linkLabel: null,
  },
];
---

<MarketingLayout
  title="Migration Guide: Bayut API to UAE Real Estate API"
  description="Important migration guide for users of the Bayut API on RapidAPI. Transition to the new UAE Real Estate API by May 12th."
  noindex={true}
>
  <div class="container px-4 pt-12 pb-16 md:pt-16 md:pb-24">

    <!-- Alert badge -->
    <div class="flex justify-center mb-10">
      <div class="inline-flex items-center gap-2 rounded-full border border-amber-400/40 bg-amber-500/10 px-4 py-1.5">
        <Icon name="lucide:alert-triangle" class="h-4 w-4 text-amber-500" />
        <span class="text-xs font-bold uppercase tracking-wider text-amber-600 dark:text-amber-400">Important Migration Required</span>
      </div>
    </div>

    <!-- Hero -->
    <div class="mx-auto max-w-4xl text-center">
      <h1 class="text-3xl font-bold tracking-tight text-foreground sm:text-4xl md:text-5xl lg:text-6xl">
        We are migrating from Bayut API<br class="hidden sm:block" />
        <span class="text-brand-600"> to UAE Real Estate API</span>
      </h1>
      <p class="mx-auto mt-6 max-w-2xl text-base leading-relaxed text-foreground-secondary sm:text-lg">
        To remain compliant with trademark regulations, we are transitioning our services from Bayut to this new, improved identity. Your integration remains 99% the same.
      </p>

      <!-- API slug mapping -->
      <div class="mt-10 flex flex-col items-center justify-center gap-3 sm:flex-row sm:gap-6">
        <div class="rounded-lg border border-border bg-background-secondary px-4 py-2 font-mono text-xs text-foreground-muted line-through sm:text-sm">
          api/bayut14
        </div>
        <Icon name="lucide:arrow-right" class="h-5 w-5 rotate-90 text-foreground-muted sm:rotate-0" />
        <div class="rounded-lg border border-success/40 bg-success/10 px-4 py-2 font-mono text-xs font-semibold text-success sm:text-sm">
          api/uae-real-estate3
        </div>
      </div>
    </div>

    <!-- Deadline + CTA card -->
    <div class="mx-auto mt-14 max-w-5xl">
      <div class="overflow-hidden rounded-2xl bg-[#07090f] text-white shadow-2xl">
        <div class="flex flex-col md:flex-row">

          <!-- Left: deadline -->
          <div class="flex flex-col justify-center p-8 md:w-2/5 lg:p-12">
            <div class="flex items-center gap-3 text-white/40">
              <Icon name="lucide:clock" class="h-5 w-5" />
              <span class="text-xs font-medium uppercase tracking-wide">Migration Deadline</span>
            </div>
            <div class="mt-4">
              <div class="text-5xl font-bold tracking-tight lg:text-6xl">May 12</div>
              <div class="mt-1 text-lg font-medium text-white/40">2026</div>
            </div>
            <div class="mt-6 inline-flex w-fit items-center gap-2 rounded-lg bg-white/10 px-3 py-1.5 text-sm font-medium">
              <span class="h-2 w-2 animate-pulse rounded-full bg-green-400"></span>
              <span id="days-left">Calculating...</span>
            </div>
          </div>

          <!-- Divider -->
          <div class="h-px w-full bg-white/10 md:h-auto md:w-px"></div>

          <!-- Right: CTA -->
          <div class="flex flex-col justify-center bg-white/[0.03] p-8 md:flex-1 lg:p-12">
            <h3 class="text-xl font-bold sm:text-2xl">Ready to switch?</h3>
            <p class="mt-3 text-sm text-white/50 sm:text-base">
              The new API is live and fully compatible. Subscribe now to ensure zero downtime for your application.
            </p>

            <div class="mt-6 flex items-center justify-between gap-3 rounded-lg border border-white/10 bg-white/5 p-3">
              <span class="truncate font-mono text-xs text-green-400 sm:text-sm">{newUrl}</span>
              <button class="copy-btn shrink-0 text-white/40 transition hover:text-white" data-copy={newUrl} aria-label="Copy link">
                <Icon name="lucide:copy" class="h-4 w-4" />
              </button>
            </div>

            <div class="mt-4 rounded-xl border border-amber-500/20 bg-amber-500/10 p-4">
              <p class="text-xs leading-relaxed text-amber-200/80">
                <span class="font-bold text-amber-400">Important:</span> Your authorization credentials may differ depending on your RapidAPI account setup. Always copy the complete snippet from the new API page to ensure compatibility.
              </p>
            </div>

            <div class="mt-8 flex flex-col gap-3 sm:flex-row">
              <a
                href={newUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex h-11 items-center justify-center gap-2 rounded-full bg-brand-600 px-8 text-sm font-bold text-white transition hover:bg-brand-700"
              >
                Subscribe on RapidAPI
                <Icon name="lucide:external-link" class="h-4 w-4" />
              </a>
              <a
                href="https://bayutapi.dev/"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex h-11 items-center justify-center rounded-full border border-white/20 bg-transparent px-8 text-sm font-bold text-white transition hover:bg-white/10"
              >
                Technical Docs
              </a>
            </div>
          </div>

        </div>
      </div>
    </div>

    <!-- What's Changing + Why new API -->
    <div class="mt-24 grid gap-12 lg:grid-cols-2 lg:gap-16">

      <!-- What's Changing -->
      <div>
        <h2 class="text-2xl font-bold tracking-tight text-foreground sm:text-3xl">What's Changing?</h2>
        <p class="mt-4 text-base text-foreground-secondary sm:text-lg">
          Only two lines in your code need to be updated. All query parameters, response objects, and logic remain identical.
        </p>

        <div class="mt-8 space-y-6">
          <!-- Host change -->
          <div class="rounded-2xl border border-border bg-card p-5 shadow-sm">
            <div class="mb-4 flex items-center justify-between">
              <span class="text-[10px] font-bold uppercase tracking-widest text-brand-600 sm:text-xs">RapidAPI Host</span>
              <Icon name="lucide:code-2" class="h-4 w-4 text-foreground-muted" />
            </div>
            <div>
              <p class="text-[10px] font-bold uppercase tracking-tight text-foreground-muted mb-1">Old</p>
              <div class="rounded-md bg-background-secondary px-3 py-2 font-mono text-sm text-foreground-muted line-through">{oldHost}</div>
            </div>
            <div class="flex justify-center my-3">
              <Icon name="lucide:arrow-down" class="h-4 w-4 text-border-strong" />
            </div>
            <div>
              <p class="text-[10px] font-bold uppercase tracking-tight text-success mb-1">New</p>
              <div class="flex items-center justify-between rounded-md border border-success/30 bg-success/10 px-3 py-2 font-mono text-sm font-semibold text-success">
                <span>{newHost}</span>
                <button class="copy-btn ml-2 shrink-0 transition hover:opacity-70" data-copy={newHost} aria-label="Copy">
                  <Icon name="lucide:copy" class="h-3.5 w-3.5" />
                </button>
              </div>
            </div>
          </div>

          <!-- Base URL change -->
          <div class="rounded-2xl border border-border bg-card p-5 shadow-sm">
            <div class="mb-4 flex items-center justify-between">
              <span class="text-[10px] font-bold uppercase tracking-widest text-brand-600 sm:text-xs">Base URL</span>
              <Icon name="lucide:external-link" class="h-4 w-4 text-foreground-muted" />
            </div>
            <div>
              <p class="text-[10px] font-bold uppercase tracking-tight text-foreground-muted mb-1">Old</p>
              <div class="truncate rounded-md bg-background-secondary px-3 py-2 font-mono text-sm text-foreground-muted line-through">https://{oldHost}</div>
            </div>
            <div class="flex justify-center my-3">
              <Icon name="lucide:arrow-down" class="h-4 w-4 text-border-strong" />
            </div>
            <div>
              <p class="text-[10px] font-bold uppercase tracking-tight text-success mb-1">New</p>
              <div class="flex items-center justify-between rounded-md border border-success/30 bg-success/10 px-3 py-2 font-mono text-sm font-semibold text-success">
                <span class="truncate">https://{newHost}</span>
                <button class="copy-btn ml-2 shrink-0 transition hover:opacity-70" data-copy={`https://${newHost}`} aria-label="Copy">
                  <Icon name="lucide:copy" class="h-3.5 w-3.5" />
                </button>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Why the new API -->
      <div class="rounded-3xl border border-border bg-card p-6 shadow-xl sm:p-8 lg:p-10">
        <h2 class="text-xl font-bold sm:text-2xl">Why the new API?</h2>
        <p class="mt-3 text-foreground-secondary">
          While the branding has changed, we took this opportunity to upgrade our infrastructure.
        </p>

        <ul class="mt-8 space-y-6">
          <li class="flex gap-4">
            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-brand-500/10 text-brand-600">
              <Icon name="lucide:zap" class="h-5 w-5" />
            </div>
            <div>
              <h4 class="font-semibold text-foreground">Faster Response Times</h4>
              <p class="mt-1 text-sm leading-relaxed text-foreground-secondary">Optimized routing and improved caching layers.</p>
            </div>
          </li>
          <li class="flex gap-4">
            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-brand-500/10 text-brand-600">
              <Icon name="lucide:shield-check" class="h-5 w-5" />
            </div>
            <div>
              <h4 class="font-semibold text-foreground">Enhanced Stability</h4>
              <p class="mt-1 text-sm leading-relaxed text-foreground-secondary">Redundant server clusters for higher availability.</p>
            </div>
          </li>
          <li class="flex gap-4">
            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-brand-500/10 text-brand-600">
              <Icon name="lucide:rocket" class="h-5 w-5" />
            </div>
            <div>
              <h4 class="font-semibold text-foreground">Improved Reliability</h4>
              <p class="mt-1 text-sm leading-relaxed text-foreground-secondary">Better error handling and data consistency checks.</p>
            </div>
          </li>
        </ul>

        <div class="mt-8 rounded-2xl border border-brand-500/20 bg-brand-500/5 p-5">
          <h4 class="flex items-center gap-2 font-bold text-brand-600">
            <Icon name="lucide:check-circle-2" class="h-5 w-5" />
            Guaranteed Compatibility
          </h4>
          <p class="mt-2 text-sm leading-relaxed text-foreground-secondary">
            The pricing, rate limits (including free tiers), query parameters, and JSON response structures are identical to the old API. Your existing data parsers will work perfectly.
          </p>
        </div>
      </div>

    </div>

    <!-- Code comparison -->
    <div class="mt-20 sm:mt-28">
      <div class="text-center">
        <h2 class="text-2xl font-bold tracking-tight text-foreground sm:text-3xl">Code Comparison</h2>
        <p class="mx-auto mt-4 max-w-2xl text-base text-foreground-secondary sm:text-lg">
          See how minimal the changes are. Just update the endpoint and host header.
        </p>
      </div>

      <div class="mt-12 grid gap-6 lg:grid-cols-2">
        <!-- Old -->
        <div class="overflow-hidden rounded-2xl border border-border bg-[#0d1117]">
          <div class="flex items-center justify-between border-b border-white/10 px-5 py-3">
            <span class="text-xs font-bold uppercase tracking-widest text-white/40">Old Configuration</span>
            <div class="flex gap-1.5">
              <span class="h-2.5 w-2.5 rounded-full bg-red-500/50"></span>
              <span class="h-2.5 w-2.5 rounded-full bg-yellow-500/50"></span>
              <span class="h-2.5 w-2.5 rounded-full bg-green-500/50"></span>
            </div>
          </div>
          <div class="p-6">
<pre class="overflow-x-auto text-[13px] leading-6 text-white/50"><code>curl --request GET \
  --url <span class="text-red-400">https://{oldHost}/health</span> \
  --header 'Content-Type: application/json' \
  --header 'x-rapidapi-host: <span class="text-red-400">{oldHost}</span>' \
  --header 'x-rapidapi-key: YOUR_API_KEY'</code></pre>
          </div>
        </div>

        <!-- New -->
        <div class="overflow-hidden rounded-2xl border border-success/30 bg-[#0d1117] ring-1 ring-success/10">
          <div class="flex items-center justify-between border-b border-white/10 bg-success/5 px-5 py-3">
            <span class="text-xs font-bold uppercase tracking-widest text-success">New Configuration</span>
            <div class="flex items-center gap-2">
              <Icon name="lucide:check-circle-2" class="h-3.5 w-3.5 text-success" />
              <span class="text-[10px] font-bold uppercase text-success">Recommended</span>
            </div>
          </div>
          <div class="p-6">
<pre class="overflow-x-auto text-[13px] leading-6 text-white/80"><code>curl --request GET \
  --url <span class="text-green-400">https://{newHost}/health</span> \
  --header 'Content-Type: application/json' \
  --header 'x-rapidapi-host: <span class="text-green-400">{newHost}</span>' \
  --header 'x-rapidapi-key: YOUR_API_KEY'</code></pre>
          </div>
        </div>
      </div>
    </div>

    <!-- 3-step guide -->
    <div class="mt-20 sm:mt-28">
      <div class="text-center">
        <h2 class="text-2xl font-bold tracking-tight text-foreground sm:text-3xl">3-Step Migration Guide</h2>
        <p class="mx-auto mt-4 max-w-2xl text-base text-foreground-secondary sm:text-lg">
          Follow these simple steps to ensure your application continues to function after May 12th.
        </p>
      </div>

      <div class="mt-12 grid gap-6 md:grid-cols-3">
        {steps.map(item => (
          <div class="relative rounded-2xl border border-border bg-card p-6 sm:p-8">
            <div class="pointer-events-none absolute right-6 top-5 select-none text-5xl font-black italic text-foreground/5">{item.step}</div>
            <h3 class="mt-4 text-lg font-bold text-foreground sm:text-xl">{item.title}</h3>
            <p class="mt-3 text-sm leading-relaxed text-foreground-secondary">{item.desc}</p>
            {item.link && (
              <a href={item.link} target="_blank" rel="noopener noreferrer" class="mt-6 inline-flex items-center gap-2 text-sm font-semibold text-brand-600 hover:underline">
                {item.linkLabel}
                <Icon name="lucide:arrow-right" class="h-4 w-4" />
              </a>
            )}
          </div>
        ))}
      </div>
    </div>

    <!-- Support section -->
    <div class="mt-20 rounded-3xl bg-[#07090f] p-8 text-center text-white sm:mt-28 lg:p-20">
      <h2 class="text-2xl font-bold tracking-tight sm:text-3xl md:text-4xl">Need help with migration?</h2>
      <p class="mx-auto mt-4 max-w-2xl text-base text-white/50 sm:mt-6 sm:text-lg">
        Our team is here to ensure your transition is seamless. Reach out if you have any questions or encounter issues.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-4 sm:mt-10">
        <a
          href="/contact"
          class="inline-flex h-12 items-center justify-center rounded-full border border-white/20 bg-transparent px-8 text-sm font-bold text-white transition hover:bg-white/10 sm:h-14 sm:px-10 sm:text-base"
        >
          Contact Support
        </a>
        <a
          href={newUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex h-12 items-center justify-center gap-2 rounded-full bg-brand-600 px-8 text-sm font-bold text-white transition hover:bg-brand-700 sm:h-14 sm:px-10 sm:text-base"
        >
          Subscribe on RapidAPI
          <Icon name="lucide:external-link" class="h-4 w-4" />
        </a>
      </div>
    </div>

    <!-- Legal disclaimer -->
    <div class="mt-16 border-t border-border pt-10">
      <p class="mx-auto max-w-4xl text-center text-xs leading-relaxed text-foreground-muted">
        <span class="font-bold">Trademark Notice:</span> "Bayut" is a trademark of its respective owner. "RapidAPI" is a trademark of RapidAPI, Inc. We are not affiliated with, endorsed by, or sponsored by Bayut or RapidAPI, Inc. All product names, logos, and brands mentioned in this document are property of their respective owners.
      </p>
    </div>

  </div>
</MarketingLayout>

<script>
  const el = document.getElementById('days-left');
  if (el) {
    const deadline = new Date('2026-05-12T00:00:00Z').getTime();
    const update = () => {
      const diff = deadline - Date.now();
      if (diff <= 0) { el.textContent = 'Deadline passed'; return; }
      const days = Math.ceil(diff / (1000 * 60 * 60 * 24));
      el.textContent = `${days} day${days === 1 ? '' : 's'} remaining`;
    };
    update();
    setInterval(update, 60_000);
  }

  document.querySelectorAll<HTMLButtonElement>('.copy-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const text = btn.dataset.copy;
      if (!text) return;
      navigator.clipboard.writeText(text).then(() => {
        const original = btn.innerHTML;
        btn.innerHTML = '<span style="font-size:10px;font-weight:700">Copied!</span>';
        setTimeout(() => { btn.innerHTML = original; }, 2000);
      });
    });
  });
</script>
