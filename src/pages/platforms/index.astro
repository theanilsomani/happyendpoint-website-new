---
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import EntityCard from '@/components/he/EntityCard.astro';
import Breadcrumbs from '@/components/he/Breadcrumbs.astro';
import FilterPanel from '@/components/he/FilterPanel.tsx';
import { getAllPublishedPlatforms, getAllCategories } from '@/lib/content-queries';

const platforms = await getAllPublishedPlatforms();
platforms.sort((a, b) => a.data.name.localeCompare(b.data.name));
const categories = await getAllCategories();

const facets = [
  {
    key: 'category',
    label: 'Category',
    options: categories.map(c => ({ value: c.id, label: c.data.name })),
  },
];
---

<MarketingLayout
  title="All platforms"
  description="Every platform Happy Endpoint covers with APIs and datasets. Browse by category or search."
>
  <Breadcrumbs items={[{ label: 'Home', href: '/' }, { label: 'Platforms' }]} />

  <section class="container py-10 md:py-14">
    <header class="max-w-2xl">
      <h1 class="text-3xl font-bold text-foreground md:text-4xl">Platforms</h1>
      <p class="mt-3 text-lg text-foreground-secondary">
        Every platform we cover. Each platform page aggregates its APIs, datasets, and free samples.
      </p>
    </header>

    <div class="mt-10 grid gap-8 md:grid-cols-[260px_1fr]">
      <FilterPanel client:load facets={facets} heading="Filter platforms" />

      <div data-filter-target>
        <div class="grid gap-4 grid-cols-1 sm:grid-cols-2 lg:grid-cols-3">
          {platforms.map(p => (
            <div
              data-entity-card
              data-variant="platform"
              data-category={p.data.category}
              data-tags={p.data.tags.join(',')}
              data-search={`${p.data.name} ${p.data.description} ${p.data.tags.join(' ')}`.toLowerCase()}
            >
              <EntityCard
                variant="platform"
                title={p.data.name}
                href={`/platforms/${p.id}`}
                description={p.data.tagline || p.data.description}
                metrics={[{ label: 'Domain', value: p.data.domain }]}
                tags={p.data.tags}
              />
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>
</MarketingLayout>
