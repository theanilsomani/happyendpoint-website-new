---
import TopicPage from '@/components/he/TopicPage.astro';
import { render } from 'astro:content';
import { getTopicHub, getTopicSubPages, resolveTopicRelations } from '@/lib/topic-routes';

const hub = await getTopicHub('finance');
if (!hub) return Astro.redirect('/404');

const { Content } = await render(hub);
const subTopics = await getTopicSubPages('finance');
const { apis, datasets } = await resolveTopicRelations(hub);
---

<TopicPage
  topic={hub}
  apis={apis}
  datasets={datasets}
  subTopics={subTopics}
  hubHref="/finance-data/"
  breadcrumbs={[{ label: 'Home', href: '/' }, { label: 'Finance Data' }]}
>
  <Content />
</TopicPage>
