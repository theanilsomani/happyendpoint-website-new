---
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import Breadcrumbs from '@/components/he/Breadcrumbs.astro';
import { Icon } from 'astro-icon/components';
import terms from '@/data/dictionary.json';

const letters = [...new Set(terms.map(t => t.term[0].toUpperCase()))].sort();
const total = terms.length;

const termsByLetter = letters.reduce<Record<string, typeof terms>>((acc, letter) => {
  acc[letter] = terms.filter(t => t.term[0].toUpperCase() === letter).sort((a, b) => a.term.localeCompare(b.term));
  return acc;
}, {});
---

<MarketingLayout
  title={`API & Data Dictionary - ${total} Terms Explained`}
  description="Definitions for APIs, datasets, real estate data, e-commerce, travel, and finance terms. A reference for developers building with live data APIs."
>
  <Breadcrumbs items={[{ label: 'Home', href: '/' }, { label: 'Dictionary' }]} />

  <section class="container py-10 md:py-14">
    <div class="max-w-2xl">
      <h1 class="text-3xl font-bold tracking-tight text-foreground md:text-4xl">API &amp; Data Dictionary</h1>
      <p class="mt-3 text-lg text-foreground-secondary">
        {total} terms covering APIs, datasets, real estate, e-commerce, travel, and finance data. Built for developers building with live data.
      </p>
    </div>

    <div class="mt-8 flex flex-col gap-4 sm:flex-row sm:items-center sm:gap-6">
      <div class="relative flex-1 max-w-md">
        <Icon name="lucide:search" class="pointer-events-none absolute left-3 top-1/2 h-4 w-4 -translate-y-1/2 text-foreground-muted" />
        <input
          id="dict-search"
          type="search"
          placeholder={`Search ${total} terms...`}
          class="w-full rounded-lg border border-border bg-background py-2.5 pl-9 pr-4 text-sm text-foreground placeholder:text-foreground-muted focus:border-brand-500 focus:outline-none focus:ring-2 focus:ring-brand-500/20"
          autocomplete="off"
        />
      </div>
    </div>

    <div class="mt-5 flex flex-wrap gap-1.5" id="letter-filter">
      <button
        data-letter="all"
        class="letter-btn rounded-md border border-brand-600 bg-brand-600 px-3 py-1.5 text-xs font-semibold text-white transition hover:bg-brand-700"
      >
        All
      </button>
      {letters.map(letter => (
        <button
          data-letter={letter}
          class="letter-btn rounded-md border border-border bg-background px-3 py-1.5 text-xs font-semibold text-foreground-secondary transition hover:border-brand-500 hover:text-brand-600"
        >
          {letter}
        </button>
      ))}
    </div>
  </section>

  <section class="container pb-16" id="terms-container">
    {letters.map(letter => (
      <div class="letter-section mb-10" data-letter={letter}>
        <h2 class="mb-4 text-sm font-bold uppercase tracking-widest text-foreground-muted">{letter}</h2>
        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
          {termsByLetter[letter].map(term => (
            <a
              href={`/dictionary/${term.slug}`}
              class="term-card group flex items-start gap-3 rounded-lg border border-border bg-card p-4 transition-colors hover:border-brand-500/50 hover:bg-brand-500/5"
              data-term={term.term.toLowerCase()}
              data-shortdef={term.shortDef.toLowerCase()}
            >
              <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-brand-500/10 text-brand-600">
                <Icon name={term.icon} class="h-4 w-4" />
              </div>
              <div class="min-w-0">
                <p class="text-sm font-semibold text-foreground group-hover:text-brand-600">{term.term}</p>
                <p class="mt-0.5 text-xs text-foreground-muted">{term.shortDef}</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    ))}

    <p id="no-results" class="hidden py-12 text-center text-foreground-secondary">
      No terms match your search. Try a different keyword.
    </p>
  </section>
</MarketingLayout>

<script>
  const searchInput = document.getElementById('dict-search') as HTMLInputElement;
  const letterBtns = document.querySelectorAll<HTMLButtonElement>('.letter-btn');
  const termCards = document.querySelectorAll<HTMLAnchorElement>('.term-card');
  const letterSections = document.querySelectorAll<HTMLDivElement>('.letter-section');
  const noResults = document.getElementById('no-results')!;

  let activeLetter = 'all';
  let searchQuery = '';

  function update() {
    let visible = 0;

    termCards.forEach(card => {
      const term = card.dataset.term ?? '';
      const shortDef = card.dataset.shortdef ?? '';
      const letter = card.closest<HTMLDivElement>('.letter-section')?.dataset.letter ?? '';

      const matchesSearch = !searchQuery || term.includes(searchQuery) || shortDef.includes(searchQuery);
      const matchesLetter = activeLetter === 'all' || letter === activeLetter;

      const show = matchesSearch && matchesLetter;
      card.style.display = show ? '' : 'none';
      if (show) visible++;
    });

    letterSections.forEach(section => {
      const hasVisible = [...section.querySelectorAll<HTMLAnchorElement>('.term-card')]
        .some(c => c.style.display !== 'none');
      section.style.display = hasVisible ? '' : 'none';
    });

    noResults.classList.toggle('hidden', visible > 0);
  }

  searchInput.addEventListener('input', () => {
    searchQuery = searchInput.value.trim().toLowerCase();
    update();
  });

  letterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      activeLetter = btn.dataset.letter ?? 'all';

      letterBtns.forEach(b => {
        const active = b.dataset.letter === activeLetter;
        b.classList.toggle('bg-brand-600', active);
        b.classList.toggle('border-brand-600', active);
        b.classList.toggle('text-white', active);
        b.classList.toggle('border-border', !active);
        b.classList.toggle('bg-background', !active);
        b.classList.toggle('text-foreground-secondary', !active);
      });

      update();
    });
  });
</script>
