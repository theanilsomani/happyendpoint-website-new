---
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import Breadcrumbs from '@/components/he/Breadcrumbs.astro';
import { Icon } from 'astro-icon/components';

const pillars = [
  {
    icon: 'lucide:zap',
    title: 'Ship in hours, not sprints',
    body: 'Every API is documented, stable, and subscribed via RapidAPI. No contracts, no sales calls — just paste the key and make requests.',
  },
  {
    icon: 'lucide:download',
    title: 'Try before you buy',
    body: 'Most datasets come with free samples in the same schema as the full version. Evaluate fit before you spend a cent.',
  },
  {
    icon: 'lucide:shield-check',
    title: 'Clean, consistent data',
    body: 'Deduplicated, validated, and refreshed on schedule. What we publish matches what the source platforms expose — no fabricated fields, no stale rows.',
  },
  {
    icon: 'lucide:layers',
    title: 'APIs or datasets — you choose',
    body: 'Live data via request? Use the API. Bulk snapshot? Buy the dataset. Historical analysis? Both — together.',
  },
  {
    icon: 'lucide:globe',
    title: 'Multi-industry coverage',
    body: 'Real-estate, travel, grocery, finance, retail, fashion, beauty. Platforms you know, from Dubai to London to the US.',
  },
  {
    icon: 'lucide:users',
    title: 'Transparent pricing',
    body: 'No surprise invoices. RapidAPI\'s per-request model is transparent; dataset pricing is quoted up front.',
  },
];
---

<MarketingLayout
  title="Why Happy Endpoint"
  description="Six reasons teams choose Happy Endpoint for web-scraping APIs and structured datasets — speed, free samples, data quality, flexible delivery, multi-industry coverage, transparent pricing."
>
  <Breadcrumbs items={[{ label: 'Home', href: '/' }, { label: 'Why Happy Endpoint' }]} />

  <section class="container py-12 md:py-16">
    <header class="max-w-2xl">
      <h1 class="text-3xl font-bold text-foreground md:text-5xl">Why teams pick Happy Endpoint</h1>
      <p class="mt-4 text-lg text-foreground-secondary">
        Data infrastructure is table stakes. We focus on making it boring — in the best way.
      </p>
    </header>

    <div class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {pillars.map(p => (
        <div class="rounded-lg border border-border bg-card p-6">
          <div class="flex h-10 w-10 items-center justify-center rounded-md bg-brand-500/10 text-brand-600">
            <Icon name={p.icon} class="h-5 w-5" />
          </div>
          <h2 class="mt-4 text-lg font-semibold text-foreground">{p.title}</h2>
          <p class="mt-2 text-sm text-foreground-secondary">{p.body}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="border-t border-border bg-background-secondary py-16">
    <div class="container max-w-3xl text-center">
      <h2 class="text-3xl font-bold text-foreground md:text-4xl">Ready to plug in?</h2>
      <p class="mt-3 text-lg text-foreground-secondary">
        Browse the catalog, or download a free sample to see what you'd be working with.
      </p>
      <div class="mt-7 flex flex-wrap justify-center gap-3">
        <a href="/library" class="inline-flex items-center gap-2 rounded-md bg-brand-500 px-5 py-2.5 text-sm font-semibold text-white hover:bg-brand-600">
          Browse APIs
        </a>
        <a href="/free-datasets" class="inline-flex items-center rounded-md border border-border-strong px-5 py-2.5 text-sm font-semibold text-foreground hover:bg-secondary">
          Download a free sample
        </a>
      </div>
    </div>
  </section>
</MarketingLayout>
