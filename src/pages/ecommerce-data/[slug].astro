---
import TopicPage from '@/components/he/TopicPage.astro';
import { render } from 'astro:content';
import { getStaticPathsForVertical, resolveTopicRelations } from '@/lib/topic-routes';
import type { CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  return getStaticPathsForVertical('ecommerce');
}

interface Props { topic: CollectionEntry<'topics'> }
const { topic } = Astro.props;
const { Content } = await render(topic);
const { apis, datasets } = await resolveTopicRelations(topic);
---

<TopicPage
  topic={topic}
  apis={apis}
  datasets={datasets}
  hubHref="/ecommerce-data/"
  breadcrumbs={[
    { label: 'Home', href: '/' },
    { label: 'Ecommerce Data', href: '/ecommerce-data/' },
    { label: topic.data.title },
  ]}
>
  <Content />
</TopicPage>
