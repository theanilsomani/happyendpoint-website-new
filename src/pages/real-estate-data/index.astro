---
import TopicPage from '@/components/he/TopicPage.astro';
import { render } from 'astro:content';
import { getTopicHub, getTopicSubPages, resolveTopicRelations } from '@/lib/topic-routes';

const hub = await getTopicHub('real-estate');
if (!hub) return Astro.redirect('/404');

const { Content } = await render(hub);
const subTopics = await getTopicSubPages('real-estate');
const { apis, datasets } = await resolveTopicRelations(hub);
---

<TopicPage
  topic={hub}
  apis={apis}
  datasets={datasets}
  subTopics={subTopics}
  hubHref="/real-estate-data/"
  breadcrumbs={[{ label: 'Home', href: '/' }, { label: 'Real Estate Data' }]}
>
  <Content />
</TopicPage>
