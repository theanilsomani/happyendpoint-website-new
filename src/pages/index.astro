---
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import EntityCard from '@/components/he/EntityCard.astro';
import EntityGrid from '@/components/he/EntityGrid.astro';
import FAQSection from '@/components/he/FAQSection.astro';
import PlatformLogosStrip from '@/components/he/PlatformLogosStrip.astro';
import { Icon } from 'astro-icon/components';
import { getCollection } from 'astro:content';
import {
  getFeaturedPlatforms,
  getFeaturedApis,
  getFeaturedDatasets,
  getAllCategories,
} from '@/lib/content-queries';

const platforms = await getFeaturedPlatforms(8);
const apis = await getFeaturedApis(6);
const datasets = await getFeaturedDatasets(6);
const categories = await getAllCategories();
categories.sort((a, b) => a.data.order - b.data.order || a.data.name.localeCompare(b.data.name));

const blogPosts = (await getCollection('blog'))
  .filter(p => !p.data.draft)
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf())
  .slice(0, 3);

const faqs = [
  {
    question: 'What does Happy Endpoint sell?',
    answer: 'Web-scraping APIs and structured datasets for real-estate, travel, grocery, finance, retail, fashion, and beauty platforms. Everything is listed on RapidAPI for instant integration.',
  },
  {
    question: 'Do I need an account on happyendpoint.com?',
    answer: 'No — the site is a catalog. Sign-up, billing, and API keys all live on RapidAPI. Every API page links straight to its RapidAPI listing.',
  },
  {
    question: 'Are free samples available?',
    answer: 'Yes. Many datasets ship with free samples you can download without an account. <a href="/free-datasets" class="text-brand-600 underline">See all free samples</a>.',
  },
  {
    question: 'What if I need a custom dataset or scraping job?',
    answer: '<a href="/contact" class="text-brand-600 underline">Contact us</a> with your use case — we frequently put together custom snapshots for specific platforms.',
  },
  {
    question: 'How is pricing structured?',
    answer: "APIs use RapidAPI's per-request model with free tiers on most endpoints. Datasets are priced per snapshot — see each dataset page for details.",
  },
  {
    question: 'What about API documentation?',
    answer: 'Full OpenAPI docs live at <a href="https://docs.happyendpoint.com" class="text-brand-600 underline">docs.happyendpoint.com</a>.',
  },
];

const apiPills = [
  // row 1
  'Property Listings', 'Agent Info', 'Market Trends', 'Bayut Data',
  // row 2
  'PropertyFinder Feeds', 'UAE Real Estate', 'Tesco Products', 'Sephora Catalog',
  // row 3
  'Rightmove Sales', 'Google Search', 'Fashion Inventory', 'Travel Rates',
];
---

<MarketingLayout
  title="APIs & datasets for the platforms that matter"
  description="Happy Endpoint sells web-scraping APIs and structured datasets on RapidAPI. Real estate, travel, grocery, finance, retail, fashion, and beauty — with free samples available."
>
  <!-- 1. Hero -->
  <section class="relative overflow-hidden bg-gradient-to-b from-background to-background-secondary pt-16">
    <div class="container py-16 md:py-24">
      <div class="grid gap-12 lg:grid-cols-2 lg:items-center">
        <!-- Left column -->
        <div>
          <div class="flex flex-wrap items-center gap-2">
            <span class="inline-flex items-center gap-1.5 rounded-full border border-border bg-card px-3 py-1 text-xs font-medium text-foreground-secondary">
              <span class="text-amber-400">★</span> 5.0 rating
            </span>
            <span class="inline-flex items-center gap-1.5 rounded-full border border-border bg-card px-3 py-1 text-xs font-medium text-foreground-secondary">
              <Icon name="lucide:users" class="h-3.5 w-3.5 text-brand-500" /> 1k+ API community
            </span>
          </div>
          <h1 class="mt-4 text-4xl font-bold tracking-tight text-foreground md:text-5xl">
            APIs and datasets for the platforms that matter
          </h1>
          <p class="mt-5 max-w-xl text-lg text-foreground-secondary">
            Scrape web data through ready-to-use APIs and structured datasets. +50 endpoints live on RapidAPI, with free samples to try first.
          </p>
          <div class="mt-8 flex flex-wrap gap-3">
            <a href="/library" class="inline-flex items-center gap-2 rounded-md bg-brand-500 px-5 py-2.5 text-sm font-semibold text-white hover:bg-brand-600">
              Browse APIs — for free
            </a>
            <a href="/datasets" class="inline-flex items-center gap-2 rounded-md border border-border-strong px-5 py-2.5 text-sm font-semibold text-foreground hover:bg-secondary">
              <Icon name="lucide:book-open" class="h-4 w-4" />
              Browse dataset library
            </a>
          </div>
        </div>

        <!-- Right column: floating API pill grid -->
        <div class="hidden lg:block" aria-hidden="true">
          <!-- Row 1: slight right offset -->
          <div class="flex flex-wrap gap-2.5 translate-x-4">
            {apiPills.slice(0, 4).map(label => (
              <span class="inline-flex items-center gap-2 rounded-full border border-border bg-card px-3.5 py-2 text-sm font-medium text-foreground shadow-sm transition hover:-translate-y-0.5 hover:shadow-md">
                <span class="flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-brand-500/10 text-brand-600">
                  <Icon name="lucide:check" class="h-3 w-3" />
                </span>
                {label}
              </span>
            ))}
          </div>
          <!-- Row 2: no offset -->
          <div class="mt-3 flex flex-wrap gap-2.5">
            {apiPills.slice(4, 8).map(label => (
              <span class="inline-flex items-center gap-2 rounded-full border border-border bg-card px-3.5 py-2 text-sm font-medium text-foreground shadow-sm transition hover:-translate-y-0.5 hover:shadow-md">
                <span class="flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-brand-500/10 text-brand-600">
                  <Icon name="lucide:check" class="h-3 w-3" />
                </span>
                {label}
              </span>
            ))}
          </div>
          <!-- Row 3: slight left offset -->
          <div class="mt-3 flex flex-wrap gap-2.5 -translate-x-4">
            {apiPills.slice(8, 12).map(label => (
              <span class="inline-flex items-center gap-2 rounded-full border border-border bg-card px-3.5 py-2 text-sm font-medium text-foreground shadow-sm transition hover:-translate-y-0.5 hover:shadow-md">
                <span class="flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-brand-500/10 text-brand-600">
                  <Icon name="lucide:check" class="h-3 w-3" />
                </span>
                {label}
              </span>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 2. Platform logos strip -->
  <PlatformLogosStrip platforms={platforms} title="Data from platforms you know" />

  <!-- 3. Featured APIs -->
  <section class="container py-16">
    <div class="flex items-end justify-between gap-6">
      <div>
        <h2 class="text-2xl font-bold text-foreground md:text-3xl">Popular APIs</h2>
        <p class="mt-2 text-foreground-secondary">Request-time data from the platforms that matter.</p>
      </div>
      <a href="/library" class="hidden shrink-0 text-sm font-semibold text-brand-600 hover:underline sm:block">
        Browse all APIs &rarr;
      </a>
    </div>
    <div class="mt-8">
      <EntityGrid columns={3}>
        {apis.map(a => (
          <EntityCard
            variant="api"
            title={a.data.name}
            href={`/library/${a.id}`}
            description={a.data.description}
            tags={a.data.tags}
          />
        ))}
      </EntityGrid>
    </div>
  </section>

  <!-- 4. Featured datasets -->
  <section class="border-t border-border bg-background-secondary py-16">
    <div class="container">
      <div class="flex items-end justify-between gap-6">
        <div>
          <h2 class="text-2xl font-bold text-foreground md:text-3xl">Popular datasets</h2>
          <p class="mt-2 text-foreground-secondary">Bulk snapshots when you need every row.</p>
        </div>
        <a href="/datasets" class="hidden shrink-0 text-sm font-semibold text-brand-600 hover:underline sm:block">
          Browse all datasets &rarr;
        </a>
      </div>
      <div class="mt-8">
        <EntityGrid columns={3}>
          {datasets.map(d => (
            <EntityCard
              variant="dataset"
              title={d.data.name}
              href={`/datasets/${d.id}`}
              description={d.data.description}
              metrics={[
                { label: 'Records', value: d.data.recordCount },
                { label: 'Format', value: d.data.format },
              ]}
              badge={d.data.price.toLowerCase() === 'free' ? 'FREE' : d.data.freeSample ? 'FREE SAMPLE' : undefined}
              tags={d.data.tags}
            />
          ))}
        </EntityGrid>
      </div>
    </div>
  </section>

  <!-- 5. Categories row -->
  <section class="container py-16">
    <h2 class="text-2xl font-bold text-foreground md:text-3xl">Browse by industry</h2>
    <p class="mt-2 text-foreground-secondary">Find the data you need, fast.</p>
    <div class="mt-8 grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
      {categories.map(c => (
        <a
          href={`/categories/${c.id}`}
          class="group flex items-center gap-3 rounded-lg border border-border bg-card px-4 py-3 transition hover:border-border-strong hover:shadow-sm"
        >
          <span class="flex h-10 w-10 items-center justify-center rounded-md bg-brand-500/10 text-brand-600">
            <Icon name="lucide:layers" class="h-5 w-5" />
          </span>
          <div class="flex-1">
            <p class="font-semibold text-foreground group-hover:text-brand-600">{c.data.name}</p>
            <p class="text-xs text-foreground-muted line-clamp-1">{c.data.tagline}</p>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- 6. Free samples CTA band -->
  <section class="border-y border-border bg-brand-500/5 py-12">
    <div class="container">
      <div class="flex flex-col items-start gap-5 md:flex-row md:items-center md:justify-between">
        <div class="max-w-2xl">
          <h2 class="text-2xl font-bold text-foreground md:text-3xl">Try it with real data, free</h2>
          <p class="mt-2 text-foreground-secondary">
            Representative samples, full schema, no account required. Perfect for evaluating fit before you subscribe.
          </p>
        </div>
        <a href="/free-datasets" class="inline-flex items-center gap-2 rounded-md bg-brand-500 px-5 py-2.5 text-sm font-semibold text-white hover:bg-brand-600">
          Browse free samples
          <Icon name="lucide:download" class="h-4 w-4" />
        </a>
      </div>
    </div>
  </section>

  <!-- 7. How it works -->
  <section class="container py-16">
    <h2 class="text-center text-2xl font-bold text-foreground md:text-3xl">From discovery to live data in three steps</h2>
    <div class="mt-10 grid gap-6 md:grid-cols-3">
      {[
        { num: '01', title: 'Browse', body: 'Find the API or dataset that matches your use case. Each listing shows features, formats, and sample data.', icon: 'lucide:search' },
        { num: '02', title: 'Subscribe', body: 'One-click subscription on RapidAPI. Free tiers on most APIs; transparent per-request pricing.', icon: 'lucide:credit-card' },
        { num: '03', title: 'Integrate', body: 'Copy the code sample, drop in your API key, and ship. Full OpenAPI docs at docs.happyendpoint.com.', icon: 'lucide:zap' },
      ].map(step => (
        <div class="relative rounded-lg border border-border bg-card p-6">
          <span class="text-xs font-bold uppercase tracking-widest text-brand-600">Step {step.num}</span>
          <div class="mt-3 flex h-10 w-10 items-center justify-center rounded-md bg-brand-500/10 text-brand-600">
            <Icon name={step.icon} class="h-5 w-5" />
          </div>
          <h3 class="mt-4 text-lg font-semibold text-foreground">{step.title}</h3>
          <p class="mt-2 text-sm text-foreground-secondary">{step.body}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- 8. Latest blog posts -->
  {blogPosts.length > 0 && (
    <section class="border-t border-border bg-background-secondary py-16">
      <div class="container">
        <div class="flex items-end justify-between gap-6">
          <div>
            <h2 class="text-2xl font-bold text-foreground md:text-3xl">Latest from the blog</h2>
            <p class="mt-2 text-foreground-secondary">Guides, comparisons, and integration walkthroughs.</p>
          </div>
          <a href="/blog" class="hidden shrink-0 text-sm font-semibold text-brand-600 hover:underline sm:block">
            All posts &rarr;
          </a>
        </div>
        <div class="mt-8 grid gap-4 md:grid-cols-3">
          {blogPosts.map(post => (
            <a href={`/blog/${post.id}`} class="group flex flex-col gap-3 rounded-lg border border-border bg-card p-5 transition hover:border-border-strong hover:shadow-md">
              <p class="text-xs font-medium uppercase tracking-wide text-foreground-muted">
                {new Date(post.data.publishedAt).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
              </p>
              <h3 class="text-lg font-semibold text-foreground group-hover:text-brand-600">{post.data.title}</h3>
              <p class="text-sm text-foreground-secondary line-clamp-2">{post.data.description}</p>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- 9. FAQ -->
  <FAQSection faqs={faqs} />

  <!-- 10. Final CTA -->
  <section class="border-t border-border bg-background py-16">
    <div class="container max-w-3xl text-center">
      <h2 class="text-3xl font-bold text-foreground md:text-4xl">Find your data, ship your product</h2>
      <p class="mt-3 text-lg text-foreground-secondary">
        {platforms.length} platforms covered. New data added every week.
      </p>
      <div class="mt-7 flex flex-wrap justify-center gap-3">
        <a href="/library" class="inline-flex items-center gap-2 rounded-md bg-brand-500 px-5 py-2.5 text-sm font-semibold text-white hover:bg-brand-600">
          Explore APIs
          <Icon name="lucide:arrow-right" class="h-4 w-4" />
        </a>
        <a href="/contact" class="inline-flex items-center rounded-md border border-border-strong px-5 py-2.5 text-sm font-semibold text-foreground hover:bg-secondary">
          Talk to us
        </a>
      </div>
    </div>
  </section>
</MarketingLayout>
